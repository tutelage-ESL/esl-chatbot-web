# ============================================================
# INFISICAL IS THE SOURCE OF TRUTH FOR ALL SECRETS.
# This file is only a reference — do NOT copy-paste values
# from here into a .env file unless you have no Infisical access.
#
# To run the project: install Infisical CLI, run `infisical login`,
# then `infisical init` in this directory, then `bun dev`.
#
# See SECRETS.md for the full setup guide.
# ============================================================

PORT=8000
NODE_ENV=development

# PostgreSQL connection string
# If your password has special chars (&, (, )), URL-encode them.
# Example: (Gochan&DB) → (Gochan%26DB)
DATABASE_URL=postgresql://user:pass@localhost:5432/esl_chatbot

REDIS_URL=redis://localhost:6379

# Wipe and reseed DB on startup (dev only)
RESET_DB=true

# JWT — generate strong random secrets for production
JWT_ACCESS_SECRET=your-access-secret-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES=7d

# Google OAuth — required for Google Sign-In
# Get this from Google Cloud Console → APIs & Services → Credentials
# See docs/services/google-oauth.md for the full setup guide
GOOGLE_CLIENT_ID=

# SendGrid (optional — placeholder for now)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── AI Providers ────────────────────────────────────────────
# See docs/services/ai-providers.md for setup guides
# See docs/ai-providers/llm.md for full provider decision + setup

# Google Gemini — LLM for Dev (Gemini 3 Flash) + FREE (2.5 Flash-Lite) + GOLD (2.5 Flash)
# Get from: https://aistudio.google.com → Get API key (free tier, no billing needed)
GEMINI_API_KEY=

# OpenAI — LLM for PREMIUM tier only (GPT-5 mini)
# Get from: https://platform.openai.com/api-keys (requires $5 minimum deposit)
OPENAI_API_KEY=

# Azure Speech Services — STT + Pronunciation Assessment (Gold + Premium tiers only)
# Get from: https://portal.azure.com → Cognitive Services → Speech
# Free tier (F0): 5 hrs STT/month + limited pronunciation — sufficient for dev
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Deepgram — STT for Dev + FREE tier (Nova-3, $200 signup credit)
# Get from: https://console.deepgram.com → Create API Key
DEEPGRAM_API_KEY=

# ── Cloudflare R2 — Audio + avatar storage ──────────────────
# Required for voice message recording storage and TTS audio replay.
# See docs/services/file-storage.md for the full setup guide.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tutelage-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── FIB Subscription API ─────────────────────────────────────
# Optional — subscription creation returns 503 if not set.
# See docs/payment/fib-web-payments-api.md for setup.
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=
FIB_ENV=stage
# Public HTTPS URL FIB POSTs subscription status changes to.
# Required in production when FIB_CLIENT_ID is set (server refuses to boot without it).
# Omit in local dev — activation is detected via polling instead.
FIB_WEBHOOK_URL=

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:3001

# ── Sentry Error Monitoring ──────────────────────────────────
# Optional — error reporting is silently disabled if not set.
# Only active in production. Get DSN from: sentry.io → Project → Settings → SDK Setup
# Leave blank in development (it's always disabled in dev/test regardless).
SENTRY_DSN=
