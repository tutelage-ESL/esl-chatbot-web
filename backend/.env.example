# Environment Variables

# Server Configuration
PORT=
NODE_ENV=
FRONTEND_URL=

# Google Gemini API
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Gemini API Configuration
# Available models: gemini-2.5-flash, gemini-2.5-pro
GEMINI_API_VERSION=
GEMINI_MODEL=

# Hugging Face API
# Get your API token from https://huggingface.co/settings/tokens


HUGGINGFACE_API_TOKEN=

OPENROUTER_API=

# Optional: Google Cloud Speech-to-Text API
# Uncomment and add your credentials if using Google Cloud Speech-to-Text
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json

# Optional: Google Sheets API for progress tracking
# Uncomment and add your credentials if using Google Sheets for progress tracking
# GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ElevenLabs API Configuration
# Get your API key from https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=


#SUPABASE CREDS

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Session Secret (for future authentication)
SESSION_SECRET=
# JWT Authentication
JWT_ACCESS_SECRET=   
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=
REFRESH_TOKEN_EXPIRES=
