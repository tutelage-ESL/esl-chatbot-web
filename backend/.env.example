# ESL Chatbot Backend - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# Session secret for signing cookies (REQUIRED - generate a random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secure-session-secret-here

# ============================================================================
# DATABASE (one of these is required)
# ============================================================================

# Option 1: Full PostgreSQL connection URL
DATABASE_URL=postgres://user:password@host:5432/database

# Option 2: Individual PostgreSQL credentials
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=esl_chatbot
# PGUSER=postgres
# PGPASSWORD=your-password

# ============================================================================
# AI SERVICES (at least one recommended)
# ============================================================================

# Google Gemini API (primary AI)
GEMINI_API_KEY=your-gemini-api-key

# HuggingFace API (fallback AI)
HUGGINGFACE_API_TOKEN=your-huggingface-token
HF_FALLBACK_MODEL=HuggingFaceH4/zephyr-7b-beta

# Groq API (alternative AI)
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=mixtral-8x7b-32768

# OpenRouter API (alternative AI)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct

# Local Ollama (optional)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b-instruct

# ============================================================================
# TEXT-TO-SPEECH SERVICES
# ============================================================================

# ElevenLabs TTS (premium voice synthesis)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE_ID=optional-default-voice-id

# Free TTS service (fallback)
# FREE_TTS_URL=http://your-tts-server
# FREE_TTS_PROVIDER=google
# FREE_TTS_VOICE=en_US-amy-medium
# FREE_TTS_LANG=en
# FREE_TTS_FORMAT=mp3

# ============================================================================
# APPLICATION CONFIG
# ============================================================================

# Server port
PORT=3001

# Node environment (development, production)
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Public event mode (bypasses auth for demos)
PUBLIC_EVENT_MODE=false
DEFAULT_EVENT_USER=TUTELAGE

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 
# 1. NEVER commit .env to version control
# 2. Use strong, unique values for SESSION_SECRET
# 3. Rotate API keys periodically
# 4. Use different keys for development/production
# 5. Keep backups of your production keys in a secure location
#
