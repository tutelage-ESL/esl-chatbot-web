generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum ClassRole {
  STUDENT
  TUTOR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ClassStatus {
  ACTIVE
  INACTIVE
}

enum SessionMode {
  TEXT
  VOICE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  TEXT
  VOICE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum GoalType {
  VOCABULARY
  SPEAKING
  GRAMMAR
  CONVERSATION
  STUDY_TIME
}

enum GoalDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum AiPersonality {
  FRIENDLY
  FORMAL
  CASUAL
  ENCOURAGING
  STRICT
  PATIENT
}

enum Plan {
  FREE
  GOLD
  PREMIUM
}

enum SubStatus {
  ACTIVE
  INACTIVE
  CANCELLED // set by payment webhook on subscription cancellation (Phase 8 — FIB/Stripe)
  PAST_DUE  // set by payment webhook on failed payment (Phase 8 — FIB/Stripe)
}

enum PaymentProvider {
  STRIPE
  FIB
  CASH
}

enum VocabSource {
  MANUAL
  SESSION
}

enum NotificationType {
  STREAK_MILESTONE
  GOAL_COMPLETED
  GOAL_ASSIGNED
  CLASS_ANNOUNCEMENT
}

enum FibSubStatus {
  DRAFT
  TRIAL
  ACTIVE
  REJECTED
  CANCELLED
}

// ─── Users ───────────────────────────────────────────────

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  email        String       @unique
  password     String? // null for Google-only accounts
  authProvider AuthProvider @default(LOCAL)
  googleId     String?      @unique // Google's unique user ID (sub field)
  displayName  String
  avatarUrl    String?
  isActive     Boolean      @default(true)
  role         Role         @default(STUDENT)
  phoneNumber  String?
  // Verification = a verified means of contact (Google link OR email OTP).
  // Either path flips the FREE subscription INACTIVE→ACTIVE. Google accounts are
  // verified on link (Google has already verified the email).
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  // One-to-one
  learnerProfile LearnerProfile?
  subscription   Subscription?
  metrics        UserMetrics?

  // One-to-many
  classUsers     ClassUser[]
  createdClasses Class[]               @relation("ClassCreator")
  sessions       ConversationSession[]
  messages       Message[]
  vocabularies   Vocabulary[]
  goals          Goal[]
  assignedGoals  Goal[]                @relation("GoalAssigner")
  progress       Progress[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications    Notification[]
  announcements    Announcement[]
  fibSubscriptions FibSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── Classes ──────────────────────────────────────────────

model Class {
  id            String      @id @default(uuid())
  className     String
  classCategory String?
  classStatus   ClassStatus @default(ACTIVE)
  // Archived classes are hidden from the default lists and are read-only:
  // no edits, code rotation, joins, or announcements until unarchived.
  archived      Boolean     @default(false)
  archivedAt    DateTime?
  createdById   String?

  // ── Class code lifecycle ──
  // classCode is the join code. It can expire, auto-refresh on expiry,
  // be manually rotated by a tutor, or be blocked entirely.
  classCode                       String    @unique
  classCodeExpiresAt              DateTime? // null = never expires (permanent)
  classCodeRefreshIntervalSeconds Int? // null = never auto-refresh
  classCodeBlocked                Boolean   @default(false)
  classCodeRefreshedAt            DateTime  @default(now())

  users         ClassUser[]
  announcements Announcement[]
  createdBy User?       @relation("ClassCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classes")
}

model ClassUser {
  id      String    @id @default(uuid())
  classId String
  userId  String
  role    ClassRole

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, userId])
  @@map("class_users")
}

// ─── Learner Profiles ────────────────────────────────────

model LearnerProfile {
  id                String  @id @default(uuid())
  userId            String  @unique
  currentLevel      String?
  targetLevel       String?
  learningPurpose   String?
  topicsOfInterest  Json?
  aiPersonality     AiPersonality?
  voiceSpeed        Float   @default(1.0)
  autoSpeak         Boolean @default(false)
  uiLanguage        String  @default("en")
  theme             String  @default("light")
  weeklyGoalMinutes Int     @default(60)
  timezone          String  @default("UTC")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("learner_profiles")
}

// ─── Subscriptions ───────────────────────────────────────

model Subscription {
  id                 String          @id @default(uuid())
  userId             String          @unique
  plan               Plan            @default(FREE)
  status             SubStatus       @default(INACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  monthlyTtsUsage    Int             @default(0)
  lastUsageReset     DateTime?

  // Payment provider tracking (null = admin-activated FREE or unverified)
  paymentProvider       PaymentProvider?
  externalCustomerId    String?          // stripe customerId (Stripe only)
  externalSubscriptionId String?         // fibPaymentId (FIB) or stripeSubscriptionId (Stripe)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ─── User Metrics ────────────────────────────────────────

model UserMetrics {
  id                    String    @id @default(uuid())
  userId                String    @unique
  totalStudyTimeMinutes Int       @default(0)
  totalWordsTyped       Int       @default(0)
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastStudyDate         DateTime?
  estimatedLevel        String?
  grammarSkill          Float     @default(0)
  vocabularySkill       Float     @default(0)
  fluencySkill          Float     @default(0)
  speakingSkill         Float     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_metrics")
}

// ─── Conversation Sessions ───────────────────────────────

model ConversationSession {
  id                String      @id @default(uuid())
  userId            String
  mode              SessionMode @default(TEXT)
  topic             String?
  summary           String?
  aiContextSnapshot Json?
  startedAt         DateTime    @default(now())
  endedAt           DateTime?
  durationSeconds   Int?
  messageCount      Int         @default(0)

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  evaluation SessionEvaluation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conversation_sessions")
}

// ─── Messages ────────────────────────────────────────────

model Message {
  id              String      @id @default(uuid())
  userId          String
  sessionId       String
  role            MessageRole
  type            MessageType @default(TEXT)
  content         String
  wordCount       Int?
  audioUrl        String?
  audioDurationSec Float?

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evaluation MessageEvaluation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messages")
}

// ─── Message Evaluations ─────────────────────────────────

model MessageEvaluation {
  id                  String  @id @default(uuid())
  messageId           String  @unique
  grammarScore        Int
  grammarErrors       Json    // [{error, correction, rule, severity}]
  vocabularyScore     Int
  vocabularyLevel     String  // detected CEFR level of words used (A1-C2)
  fluencyScore        Int
  pronunciationScore  Int?    // voice sessions only
  pronunciationIssues Json?   // [{word, issue, suggestion}]
  overallScore        Int     // weighted composite (0-100)
  detectedCefrLevel   String  // detected CEFR level of this message (A1-C2)
  corrections         Json    // [{original, corrected, explanation}]
  feedback            String  // human-readable summary from AI
  newWords            Json?   // [{word, definition, partOfSpeech?, example?}] — vocabulary worth studying

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("message_evaluations")
}

// ─── Session Evaluations ─────────────────────────────────

model SessionEvaluation {
  id                String @id @default(uuid())
  sessionId         String @unique
  topicsCovered     Json   // string[]
  avgGrammarScore      Float
  avgVocabularyScore   Float
  avgFluencyScore      Float
  avgOverallScore      Float
  avgPronunciationScore Float? // null for text sessions
  detectedCefrLevel    String // overall session CEFR level
  strengths         Json   // string[]
  weaknesses        Json   // string[]
  recommendations   Json   // string[]
  newVocabulary     Json   // words to feed into SRS
  totalUserMessages Int
  totalUserWords    Int

  session ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("session_evaluations")
}

// ─── Vocabularies ────────────────────────────────────────

model Vocabulary {
  id             String    @id @default(uuid())
  userId         String
  word           String
  definition     String
  pronunciation  String?
  example        String?
  partOfSpeech   String?
  difficulty     Int       @default(1)
  category       String?
  srsInterval    Int       @default(1)
  srsDue         DateTime  @default(now())
  srsEase        Float     @default(2.5)
  reviewCount    Int       @default(0)
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)
  masteryLevel   Int         @default(0)
  lastPracticed  DateTime?
  source         VocabSource @default(MANUAL)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, word])
  @@map("vocabularies")
}

// ─── Goals ───────────────────────────────────────────────

model Goal {
  id                 String     @id @default(uuid())
  userId             String
  assignedByTutorId  String?
  type               GoalType
  description        String
  target             Int
  difficulty         GoalDifficulty?
  status             GoalStatus @default(ACTIVE)
  progress           Float      @default(0)
  actionPlan         String?
  startDate          DateTime   @default(now())
  targetDate         DateTime?
  completedDate      DateTime?
  lastProgressUpdate DateTime?

  user            User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByTutor User? @relation("GoalAssigner", fields: [assignedByTutorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("goals")
}

// ─── Progress ────────────────────────────────────────────

model Progress {
  id                  String   @id @default(uuid())
  userId              String
  date                DateTime @db.Date
  sessionsCount       Int      @default(0)
  studyMinutes        Int      @default(0)
  messagesCount       Int      @default(0)
  wordsTyped          Int      @default(0)
  vocabularyPracticed Int      @default(0)
  goalsAdvanced       Int      @default(0)
  pronunciationScore  Float?
  skillSnapshot       Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("progress")
}

// ─── Password Reset Tokens ───────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  otpHash   String    @unique // SHA-256 hash of the 6-digit OTP
  expiresAt DateTime
  usedAt    DateTime? // null = unused; set on redemption

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Email Verification Tokens ───────────────────────────

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  otpHash   String    @unique // SHA-256 hash of the 6-digit OTP
  expiresAt DateTime
  usedAt    DateTime? // null = unused; set on redemption

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("email_verification_tokens")
}

// ─── Refresh Tokens ──────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Announcements ───────────────────────────────────────

model Announcement {
  id       String @id @default(uuid())
  classId  String
  authorId String
  content  String

  class  Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("announcements")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id      String           @id @default(uuid())
  userId  String
  type    NotificationType
  message String
  read    Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

// ─── FIB Subscription Audit ──────────────────────────────

model FibSubscription {
  id                String       @id @default(uuid())
  userId            String
  fibSubscriptionId String       @unique // UUID issued by FIB on createSubscription
  plan              Plan                 // GOLD or PREMIUM
  intervalMonths    Int                  // 1 | 3 | 6 | 12
  amountIQD         Int                  // amount sent to FIB at creation (locked in)
  fibStatus         FibSubStatus @default(DRAFT)
  validUntil        DateTime?            // QR code expiry from createSubscription response
  activatedAt       DateTime?            // set when fibStatus first becomes ACTIVE or TRIAL
  cancelledAt       DateTime?            // set when fibStatus becomes CANCELLED or REJECTED

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("fib_subscriptions")
}
