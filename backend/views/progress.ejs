<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progress Tracker · ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>���</text></svg>">
</head>
<body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

    <main class="page-shell">
        <section class="hero-banner">
            <div class="hero-content">
                <div class="hero-copy">
                    <p class="tag">Progress tracker</p>
                    <h1>Keep your English streak alive.</h1>
                    <p>Every chat, drill, and pronunciation check strengthens your fluency. Here's a snapshot of how you're improving this week.</p>
                    <div class="hero-actions">
                        <a href="/chat" class="btn btn-primary">Start a live session</a>
                        <a href="/goals" class="ghost-link">Review goals</a>
                    </div>
                </div>
                <div class="stat-grid">
                    <div class="stat-card">
                        <strong><%= stats.studyTime %></strong>
                        <span>Active study time</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.dayStreak %></strong>
                        <span>Day streak</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.weeklyGoal %>%</strong>
                        <span>Weekly goal</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.completionRate %>%</strong>
                        <span>Session completion</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel-grid double">
            <article class="panel">
                <div class="section-heading">
                    <h2>Learning metrics</h2>
                    <span class="badge"><i class="fas fa-chart-line"></i> Updated <%= (progress && progress.updatedAt) ? new Date(progress.updatedAt).toLocaleDateString() : 'today' %></span>
                </div>
                <div class="data-stack">
                    <div class="data-row">
                        <span>Overall progress</span>
                        <strong><%= progress && progress.progress ? progress.progress + '%' : 'Tracking' %></strong>
                    </div>
                    <div class="data-row">
                        <span>Average session time</span>
                        <strong><%= stats.averageSessionTime %></strong>
                    </div>
                    <div class="data-row">
                        <span>Total sessions logged</span>
                        <strong><%= stats.totalSessions %></strong>
                    </div>
                    <div class="data-row">
                        <span>Messages sent to coach</span>
                        <strong><%= (progress && progress.chatMessageCount) || 0 %></strong>
                    </div>
                    <div class="data-row">
                        <span>Words typed this week</span>
                        <strong><%= (progress && progress.totalWordsTyped) || 0 %></strong>
                    </div>
                </div>
            </article>

            <article class="panel">
                <div class="section-heading">
                    <h2>Focus this week</h2>
                    <span class="badge"><i class="fas fa-bullseye"></i> Tiny steps matter</span>
                </div>
                <div class="data-stack">
                    <div class="data-row" style="flex-direction: column; align-items: flex-start; gap:0.5rem;">
                        <div style="width:100%; display:flex; justify-content: space-between; align-items:center;">
                            <strong>Goal completion</strong>
                            <small><%= stats.weeklyGoal %>% of target sessions</small>
                        </div>
                        <div class="progress-track">
                            <small>Weekly cadence</small>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill" style="width:<%= stats.weeklyGoal %>%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="data-row" style="flex-direction: column; align-items: flex-start; gap:0.5rem;">
                        <div style="width:100%; display:flex; justify-content: space-between; align-items:center;">
                            <strong>Completion rate</strong>
                            <small><%= stats.completionRate %>% successful sessions</small>
                        </div>
                        <div class="progress-track">
                            <small>Quality sessions</small>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill" style="width:<%= stats.completionRate %>%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="data-row" style="flex-direction: column; align-items: flex-start; gap:0.5rem;">
                        <div style="width:100%; display:flex; justify-content: space-between; align-items:center;">
                            <strong>Voice practice</strong>
                            <small><%= (progress && progress.voiceSessions) || 0 %> mini labs logged</small>
                        </div>
                        <div class="progress-track">
                            <small>Confidence curve</small>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill" style="width:<%= Math.min(100, ((progress && progress.voiceSessions) || 0) * 10) %>%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </article>
        </section>

        <section class="panel">
            <div class="section-heading">
                <h2>Recent activity</h2>
                <a href="/usage" class="ghost-link">See detailed usage</a>
            </div>
            <% const activities = (progress && progress.activities) || []; %>
            <% if (activities.length > 0) { %>
                <div class="timeline">
                    <% activities.slice(0, 6).forEach(function(activity) { %>
                        <div class="timeline-item">
                            <span class="timeline-dot"></span>
                            <div class="timeline-content">
                                <div class="section-heading" style="margin-bottom:0.35rem;">
                                    <strong><%= activity.title || activity.type || 'Learning moment' %></strong>
                                    <small class="muted"><%= activity.date || activity.timestamp || '' %></small>
                                </div>
                                <p class="muted"><%= activity.description || activity.detail || activity.summary || 'Progress captured during your session.' %></p>
                                <% if (activity.score || activity.points) { %>
                                    <span class="badge">
                                        <i class="fas fa-star"></i>
                                        +<%= activity.score || activity.points %> pts
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No activity recorded yet. Start a chat or a practice session to see your journey fill in.</p>
                </div>
            <% } %>
        </section>
    </main>
</body>
</html>
