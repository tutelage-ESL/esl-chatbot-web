<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
 </head>
 <body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

        <main class="page-shell">
            <section class="hero-banner">
                <div class="hero-content">
                    <div class="hero-copy">
                        <p class="tag">Account</p>
                        <h1><i class="fas fa-user-circle"></i> Student Profile</h1>
                        <p>Manage your account information and learning preferences.</p>
                    </div>
                </div>
            </section>
            <section class="panel">
                
                <div class="profile-container">
                    <!-- Personal Information Card -->
                    <div class="profile-card">
                        <div class="card-header">
                            <h3><i class="fas fa-user"></i> Personal Information</h3>
                            <button type="button" class="edit-btn" onclick="toggleEdit('personal')">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </div>
                        <form id="personal-form" class="profile-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="first-name">First Name</label>
                                    <input type="text" id="first-name" name="firstName" value="<%= student.firstName || 'Not Set' %>" readonly>
                                </div>
                                <div class="form-group">
                                    <label for="last-name">Last Name</label>
                                    <input type="text" id="last-name" name="lastName" value="<%= student.lastName || 'Not Set' %>" readonly>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="email">Email Address</label>
                                    <input type="email" id="email" name="email" value="<%= student.email || 'Not Set' %>" readonly>
                                </div>
                                <div class="form-group">
                                    <label for="phone">Phone Number</label>
                                    <input type="tel" id="phone" name="phone" value="<%= student.phone || 'Not Set' %>" readonly>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="date-of-birth">Date of Birth</label>
                                <input type="date" id="date-of-birth" name="dateOfBirth" value="<%= student.dateOfBirth || '' %>" readonly>
                            </div>
                            <div class="form-actions" id="personal-actions" style="display: none;">
                                <button type="button" class="btn btn-save" onclick="saveSection('personal')">
                                    <i class="fas fa-save"></i> Save Changes
                                </button>
                                <button type="button" class="btn btn-cancel" onclick="cancelEdit('personal')">
                                    <i class="fas fa-times"></i> Cancel
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Learning Profile Card -->
                    <div class="profile-card">
                        <div class="card-header">
                            <h3><i class="fas fa-graduation-cap"></i> Learning Profile</h3>
                            <button type="button" class="edit-btn" onclick="toggleEdit('learning')">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </div>
                        <form id="learning-form" class="profile-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="current-level">Current English Level</label>
                                    <select id="current-level" name="currentLevel" disabled>
                                        <option value="Beginner" <%= (student.level === 'Beginner') ? 'selected' : '' %>>Beginner (A1)</option>
                                        <option value="Elementary" <%= (student.level === 'Elementary') ? 'selected' : '' %>>Elementary (A2)</option>
                                        <option value="Intermediate" <%= (student.level === 'Intermediate') ? 'selected' : '' %>>Intermediate (B1)</option>
                                        <option value="Upper Intermediate" <%= (student.level === 'Upper Intermediate') ? 'selected' : '' %>>Upper Intermediate (B2)</option>
                                        <option value="Advanced" <%= (student.level === 'Advanced') ? 'selected' : '' %>>Advanced (C1)</option>
                                        <option value="Proficient" <%= (student.level === 'Proficient') ? 'selected' : '' %>>Proficient (C2)</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="target-level">Target Level</label>
                                    <select id="target-level" name="targetLevel" disabled>
                                        <option value="Beginner" <%= (student.targetLevel === 'Beginner') ? 'selected' : '' %>>Beginner (A1)</option>
                                        <option value="Elementary" <%= (student.targetLevel === 'Elementary') ? 'selected' : '' %>>Elementary (A2)</option>
                                        <option value="Intermediate" <%= (student.targetLevel === 'Intermediate') ? 'selected' : '' %>>Intermediate (B1)</option>
                                        <option value="Upper Intermediate" <%= (student.targetLevel === 'Upper Intermediate') ? 'selected' : '' %>>Upper Intermediate (B2)</option>
                                        <option value="Advanced" <%= (student.targetLevel === 'Advanced') ? 'selected' : '' %>>Advanced (C1)</option>
                                        <option value="Proficient" <%= (student.targetLevel === 'Proficient') ? 'selected' : '' %>>Proficient (C2)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="learning-goals">Learning Goals</label>
                                <textarea id="learning-goals" name="learningGoals" rows="3" readonly><%= (student.learningGoals && student.learningGoals.length > 0) ? student.learningGoals.join(', ') : 'No learning goals set yet.' %></textarea>
                            </div>
                            <div class="form-group">
                                <label>Focus Areas</label>
                                <div class="checkbox-group">
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Grammar" <%= (student.focusAreas && student.focusAreas.includes('Grammar')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Grammar
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Vocabulary" <%= (student.focusAreas && student.focusAreas.includes('Vocabulary')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Vocabulary
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Pronunciation" <%= (student.focusAreas && student.focusAreas.includes('Pronunciation')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Pronunciation
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Listening" <%= (student.focusAreas && student.focusAreas.includes('Listening')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Listening
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Writing" <%= (student.focusAreas && student.focusAreas.includes('Writing')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Writing
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="focusAreas" value="Reading" <%= (student.focusAreas && student.focusAreas.includes('Reading')) ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Reading
                                    </label>
                                </div>
                            </div>
                            <div class="form-actions" id="learning-actions" style="display: none;">
                                <button type="button" class="btn btn-save" onclick="saveSection('learning')">
                                    <i class="fas fa-save"></i> Save Changes
                                </button>
                                <button type="button" class="btn btn-cancel" onclick="cancelEdit('learning')">
                                    <i class="fas fa-times"></i> Cancel
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- App Settings Card -->
                    <div class="profile-card">
                        <div class="card-header">
                            <h3><i class="fas fa-cog"></i> App Settings</h3>
                            <button type="button" class="edit-btn" onclick="toggleEdit('settings')">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </div>
                        <form id="settings-form" class="profile-form" action="/settings" method="post">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="language-select">Interface Language</label>
                                    <select id="language-select" name="language" disabled>
                                        <option value="English" <%= (student.interfaceLanguage === 'English') ? 'selected' : '' %>>English</option>
                                        <option value="Spanish" <%= (student.interfaceLanguage === 'Spanish') ? 'selected' : '' %>>Spanish</option>
                                        <option value="French" <%= (student.interfaceLanguage === 'French') ? 'selected' : '' %>>French</option>
                                        <option value="German" <%= (student.interfaceLanguage === 'German') ? 'selected' : '' %>>German</option>
                                        <option value="Italian" <%= (student.interfaceLanguage === 'Italian') ? 'selected' : '' %>>Italian</option>
                                        <option value="Portuguese" <%= (student.interfaceLanguage === 'Portuguese') ? 'selected' : '' %>>Portuguese</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="timezone">Timezone</label>
                                    <select id="timezone" name="timezone" disabled>
                                        <option value="Asia/Baghdad" <%= (student.timezone === 'Asia/Baghdad') ? 'selected' : '' %>>Baghdad Time (UTC+3)</option>
                                        <option value="UTC-5" <%= (student.timezone === 'UTC-5') ? 'selected' : '' %>>Eastern Time (UTC-5)</option>
                                        <option value="UTC-6" <%= (student.timezone === 'UTC-6') ? 'selected' : '' %>>Central Time (UTC-6)</option>
                                        <option value="UTC-7" <%= (student.timezone === 'UTC-7') ? 'selected' : '' %>>Mountain Time (UTC-7)</option>
                                        <option value="UTC-8" <%= (student.timezone === 'UTC-8') ? 'selected' : '' %>>Pacific Time (UTC-8)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="voice-speed">Voice Speed</label>
                                    <div class="range-input">
                                        <input type="range" id="voice-speed" name="voiceSpeed" min="0.5" max="2" step="0.1" value="<%= (student.voiceSpeed === 'Slow') ? '0.8' : (student.voiceSpeed === 'Fast') ? '1.5' : '1.0' %>" disabled>
                                        <span id="speed-value"><%= (student.voiceSpeed === 'Slow') ? '0.8' : (student.voiceSpeed === 'Fast') ? '1.5' : '1.0' %>x</span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="theme-select">Theme</label>
                                    <select id="theme-select" name="theme" disabled>
                                        <option value="Light" <%= (student.theme === 'Light') ? 'selected' : '' %>>Light</option>
                                        <option value="Dark" <%= (student.theme === 'Dark') ? 'selected' : '' %>>Dark</option>
                                        <option value="Auto" <%= (student.theme === 'Auto') ? 'selected' : '' %>>Auto</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Notifications</label>
                                <div class="checkbox-group">
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="notifications" value="autoSpeak" <%= settings.autoSpeak ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Auto-speak Bot Responses
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="notifications" value="dailyReminder" <%= student.notifications ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Daily Learning Reminders
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="notifications" value="progressUpdates" <%= student.notifications ? 'checked' : '' %> disabled>
                                        <span class="checkmark"></span>
                                        Progress Updates
                                    </label>
                                    <label class="checkbox-label">
                                        <input type="checkbox" name="notifications" value="achievements" checked disabled>
                                        <span class="checkmark"></span>
                                        Achievement Notifications
                                    </label>
                                </div>
                            </div>
                            <div class="form-actions" id="settings-actions" style="display: none;">
                                <button type="submit" class="btn btn-save">
                                    <i class="fas fa-save"></i> Save Settings
                                </button>
                                <button type="button" class="btn btn-cancel" onclick="cancelEdit('settings')">
                                    <i class="fas fa-times"></i> Cancel
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Account Security Card -->
                    <div class="profile-card">
                        <div class="card-header">
                            <h3><i class="fas fa-shield-alt"></i> Account Security</h3>
                        </div>
                        <div class="security-info">
                            <div class="security-item">
                                <div class="security-label">
                                    <i class="fas fa-key"></i>
                                    <span>Password</span>
                                </div>
                                <div class="security-value">
                                    <span>••••••••••••</span>
                                    <button type="button" class="btn btn-link" onclick="changePassword()">
                                        Change Password
                                    </button>
                                </div>
                            </div>
                            <div class="security-item">
                                <div class="security-label">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Last Login</span>
                                </div>
                                <div class="security-value">
                                    <span>Today, 2:30 PM</span>
                                </div>
                            </div>
                            <div class="security-item">
                                <div class="security-label">
                                    <i class="fas fa-user-plus"></i>
                                    <span>Account Created</span>
                                </div>
                                <div class="security-value">
                                    <span>January 15, 2024</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const voiceSpeedInput = document.getElementById('voice-speed');
        const speedValueSpan = document.getElementById('speed-value');

        // Initialize display
        speedValueSpan.textContent = voiceSpeedInput.value + 'x';

        // Update display on slider change
        voiceSpeedInput.addEventListener('input', () => {
            speedValueSpan.textContent = voiceSpeedInput.value + 'x';
        });
    });

    function toggleEdit(section) {
        const form = document.getElementById(section + '-form');
        const actions = document.getElementById(section + '-actions');
        const editBtn = form.closest('.profile-card').querySelector('.edit-btn');
        
        // Enable/disable form fields
        const inputs = form.querySelectorAll('input, select, textarea');
        inputs.forEach(input => {
            if (input.hasAttribute('readonly')) {
                input.removeAttribute('readonly');
            } else if (input.hasAttribute('disabled')) {
                input.removeAttribute('disabled');
            } else {
                if (input.type === 'text' || input.type === 'email' || input.type === 'tel' || input.type === 'date' || input.tagName === 'TEXTAREA') {
                    input.setAttribute('readonly', 'readonly');
                } else {
                    input.setAttribute('disabled', 'disabled');
                }
            }
        });
        
        // Toggle action buttons
        if (actions.style.display === 'none') {
            actions.style.display = 'flex';
            editBtn.innerHTML = '<i class="fas fa-times"></i> Cancel';
            editBtn.classList.add('editing');
        } else {
            actions.style.display = 'none';
            editBtn.innerHTML = '<i class="fas fa-edit"></i> Edit';
            editBtn.classList.remove('editing');
        }
    }

    function saveSection(section) {
        // Here you would typically send the data to the server
        alert('Changes saved successfully!');
        toggleEdit(section);
    }

    function cancelEdit(section) {
        // Reset form to original values
        toggleEdit(section);
    }

    function changePassword() {
        alert('Password change functionality would be implemented here.');
    }
</script>
        </main>

    
</body>
</html>