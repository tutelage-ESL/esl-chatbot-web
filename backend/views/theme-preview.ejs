<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brand Glassmorphism Mockups – ESL Academy</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
  <link rel="stylesheet" href="/css/style.css"> <!-- Tailwind tokens if needed -->
  <link rel="stylesheet" href="/css/brand-glass.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="brand-surface">
  <div class="brand-container">
    <header class="brand-header">
      <div class="brand-title">
        <div class="brand-logo" aria-label="ESL Academy Logo">🎓</div>
        <h1 class="brand-heading">ESL Academy</h1>
      </div>
      <p class="brand-tagline">Master English with AI‑Powered Learning</p>
      <nav class="brand-nav" aria-label="Primary">
        <a class="nav-chip is-active" href="#">Dashboard</a>
        <a class="nav-chip" href="#">Chat</a>
        <a class="nav-chip" href="#">Vocabulary</a>
        <a class="nav-chip" href="#">Pronunciation</a>
        <a class="nav-chip" href="#">Progress</a>
        <a class="nav-chip" href="#">Settings</a>
      </nav>
    </header>

    <main class="brand-main">
      <!-- Hero (Tutelage-style) -->
      <section class="brand-hero">
        <h2 class="hero-title">Pioneers of Excellence</h2>
        <p class="hero-subtitle">Join Tutelage and let your language skills become your super power.</p>
        <div class="hero-actions">
          <button class="btn btn-primary"><i class="fas fa-bolt"></i> Get Started</button>
          <button class="btn btn-secondary"><i class="fas fa-calendar"></i> Book a Class</button>
        </div>
      </section>

      <!-- Services -->
      <section class="demo-section">
        <h3>Our Services</h3>
        <div class="services-grid">
          <div class="service-card">
            <div class="card-content">
              <div class="service-icon"><i class="fas fa-graduation-cap"></i></div>
              <div class="card-title">IELTS & TOEFL Prep</div>
              <p class="card-meta">Comprehensive prep with proven strategies and expert guidance.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="card-content">
              <div class="service-icon"><i class="fas fa-briefcase"></i></div>
              <div class="card-title">Business English</div>
              <p class="card-meta">Professional communication skills for corporate success.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="card-content">
              <div class="service-icon"><i class="fas fa-chalkboard-teacher"></i></div>
              <div class="card-title">Private Tutoring</div>
              <p class="card-meta">One‑on‑one personalized instruction tailored to your goals.</p>
            </div>
          </div>
          <div class="service-card">
            <div class="card-content">
              <div class="service-icon"><i class="fas fa-rocket"></i></div>
              <div class="card-title">Intensive Courses</div>
              <p class="card-meta">Accelerated learning programs for rapid proficiency.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Timeline / Reputation -->
      <section class="demo-section">
        <h3>Our Story</h3>
        <div class="glass-card">
          <div class="card-content">
            <div class="timeline">
              <div class="t-item"><span class="t-dot"></span><div class="t-title">2022 — Foundation</div><div class="t-meta">Revolutionizing English learning through innovative methods.</div></div>
              <div class="t-item"><span class="t-dot"></span><div class="t-title">Innovation</div><div class="t-meta">First institute to implement full‑scale AI tools for students.</div></div>
              <div class="t-item"><span class="t-dot"></span><div class="t-title">Expansion</div><div class="t-meta">Hiring creative local talents and fresh graduates.</div></div>
              <div class="t-item"><span class="t-dot"></span><div class="t-title">Reputation</div><div class="t-meta">Among the most reputable institutes with high success rates.</div></div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Footer -->
      <section class="demo-section">
        <div class="glass-card">
          <div class="card-content" style="display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap;">
            <div>
              <div class="card-title">Ready to start?</div>
              <p class="card-meta">Experience personalized learning with expert instructors.</p>
            </div>
            <div>
              <button class="btn btn-primary"><i class="fas fa-user-plus"></i> Register Now</button>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>