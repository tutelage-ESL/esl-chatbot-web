<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Dashboard · ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>���</text></svg>">
</head>
<body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

    <main class="page-shell">
        <section class="hero-banner">
            <div class="hero-content">
                <div class="hero-copy">
                    <p class="tag">Welcome back Tutelage</p>
                    <h1 class="hero-title">Your Ai partner is here..</h1>
                    <p class="hero-subtitle">start practicing your daily dose of English</p>
                    <div class="hero-actions">
                        <a href="/chat" class="btn btn-primary">Jump into chat</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel">
            <h2>Today's focus</h2>
            <p class="muted">Pick a quick action to keep the momentum going.</p>
            <div class="focus-grid" style="margin-top:1rem;">
                <a href="/chat" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-bolt"></i></div>
                    <div class="focus-content">
                        <h3>Immediate feedback</h3>
                    </div>
                </a>
                <a href="/chat" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-comments"></i></div>
                    <div class="focus-content">
                        <h3>Real conversation</h3>
                    </div>
                </a>
                <a href="/vocabulary" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-graduation-cap"></i></div>
                    <div class="focus-content">
                        <h3>Fully ESL centered</h3>
                    </div>
                </a>
                <a href="/chat" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-clock"></i></div>
                    <div class="focus-content">
                        <h3>24/7 available, practice non stop</h3>
                    </div>
                </a>
                <a href="/goals" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-language"></i></div>
                    <div class="focus-content">
                        <h3>Designed for core language purposes</h3>
                    </div>
                </a>
                <a href="/progress" class="focus-card">
                    <div class="focus-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="focus-content">
                        <h3>Tracks your learning progress</h3>
                    </div>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
