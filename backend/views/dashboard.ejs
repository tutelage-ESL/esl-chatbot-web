<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Dashboard · ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>���</text></svg>">
</head>
<body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

    <main class="page-shell">
        <section class="hero-banner">
            <div class="hero-content">
                <div class="hero-copy">
                    <p class="tag">Welcome back</p>
                    <h1>Hi <%= user.username %>, your English streak is alive.</h1>
                    <p>Keep growing your vocabulary, speaking confidence, and listening precision with a daily mix of live chat, drills, and AI feedback.</p>
                    <div class="hero-actions">
                        <a href="/chat" class="btn btn-primary">Jump into chat</a>
                        <a href="/progress" class="ghost-link">Review analytics</a>
                    </div>
                </div>
                <div class="stat-grid">
                    <div class="stat-card">
                        <strong><%= stats.lessonsCompleted %></strong>
                        <span>Lessons completed</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.studyTime %></strong>
                        <span>Active study time</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.dayStreak %>���</strong>
                        <span>Day streak</span>
                    </div>
                    <div class="stat-card">
                        <strong><%= stats.achievements %></strong>
                        <span>Milestones unlocked</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel">
            <h2>Today's focus</h2>
            <p class="muted">Pick a quick action to keep the momentum going.</p>
            <div class="card-grid" style="margin-top:1rem;">
                <a href="/chat" class="insight-card">
                    <h3><i class="fas fa-comments"></i> Practice conversation</h3>
                    <p>10-minute guided dialogue with instant grammar cues.</p>
                </a>
                <a href="/voice" class="insight-card">
                    <h3><i class="fas fa-microphone"></i> Voice lab</h3>
                    <p>Warm up with pronunciation drills and TTS playback.</p>
                </a>
                <a href="/vocabulary" class="insight-card">
                    <h3><i class="fas fa-book"></i> Vocabulary builder</h3>
                    <p>Review saved words and unlock fresh phrases.</p>
                </a>
                <a href="/goals" class="insight-card">
                    <h3><i class="fas fa-bullseye"></i> Learning goals</h3>
                    <p>Update targets and celebrate completed milestones.</p>
                </a>
                <a href="/progress" class="insight-card">
                    <h3><i class="fas fa-chart-line"></i> Track progress</h3>
                    <p>See growth across speaking, listening, and vocabulary.</p>
                </a>
                <a href="/pronunciation" class="insight-card">
                    <h3><i class="fas fa-volume-up"></i> Pronunciation coach</h3>
                    <p>Upload phrases and get phonetic corrections.</p>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
