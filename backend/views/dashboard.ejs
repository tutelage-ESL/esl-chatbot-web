<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Dashboard · ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>���</text></svg>">
</head>
<body class="brand-surface dark-theme">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

    <main class="page-shell">
        <section class="interactive-3d parallax-hero">
            <div class="interactive-3d__content">
                <h2 class="interactive-3d__title">TUTELAGE A.I</h2>
                <p class="interactive-3d__copy">THE FUTURE OF EDUCATION NOW AVALIBLE AT THE CLICK OF A BUTTON , ENHANCING LEARNING AND IMPROVING RESULTS.</p>
            </div>
            <div class="interactive-3d__scene">
                <canvas id="spline-canvas"></canvas>
            </div>
            <div class="interactive-3d__spotlight" aria-hidden="true"><canvas id="spotlight-overlay"></canvas></div>
        </section>
        <script type="module">
            import { Application } from 'https://unpkg.com/@splinetool/runtime@1.9.20/build/runtime.js';
            const canvas = document.getElementById('spline-canvas');
            const scene = document.querySelector('.interactive-3d__scene');
            const section = document.querySelector('.interactive-3d');
            const spotCanvas = document.getElementById('spotlight-overlay');
            const spotCtx = spotCanvas.getContext('2d');
            spotCtx.imageSmoothingEnabled = true
            spotCtx.imageSmoothingQuality = 'high'
            const app = new Application(canvas);

            function resizeCanvas() {
              const rect = scene.getBoundingClientRect();
              canvas.style.width = rect.width + 'px';
              canvas.style.height = rect.height + 'px';
              const dpr = Math.min(window.devicePixelRatio || 1, 2);
              canvas.width = Math.floor(rect.width * dpr);
              canvas.height = Math.floor(rect.height * dpr);
              const sRect = section.getBoundingClientRect();
              spotCanvas.style.width = sRect.width + 'px';
              spotCanvas.style.height = sRect.height + 'px';
              const sdpr = Math.min(window.devicePixelRatio || 1, 2);
              spotCanvas.width = Math.floor(sRect.width * sdpr);
              spotCanvas.height = Math.floor(sRect.height * sdpr);
              spotCtx.setTransform(sdpr, 0, 0, sdpr, 0, 0);
            }
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            app.load('https://prod.spline.design/kZDDjO5HuC9GJUM2/scene.splinecode');

            let hover = false
            let targetX = 28
            let targetY = 22
            let currentX = 28
            let currentY = 22
            const clamp = (v, min, max) => Math.max(min, Math.min(max, v))
            section.addEventListener('mouseenter', () => { hover = true })
            section.addEventListener('mouseleave', () => {
              hover = false
              targetX = 28
              targetY = 22
            })
            section.addEventListener('mousemove', (e) => {
              if (!hover) return
              const rect = section.getBoundingClientRect()
              const x = ((e.clientX - rect.left) / rect.width) * 100
              const y = ((e.clientY - rect.top) / rect.height) * 100
              targetX = clamp(x, 6, 94)
              targetY = clamp(y, 8, 92)
            })
            function animateSpotlight() {
              currentX += (targetX - currentX) * 0.20
              currentY += (targetY - currentY) * 0.20
              const sRect = section.getBoundingClientRect()
              const x = (currentX / 100) * sRect.width
              const y = (currentY / 100) * sRect.height
              spotCtx.clearRect(0, 0, spotCanvas.width, spotCanvas.height)
              spotCtx.save()
              spotCtx.globalCompositeOperation = 'screen'

              const coreRadius = Math.min(sRect.width, sRect.height) * 0.22
              spotCtx.translate(x, y)
              spotCtx.rotate(-24 * Math.PI / 180)
              spotCtx.scale(0.42, 1.85)
              const core = spotCtx.createRadialGradient(0, 0, 0, 0, 0, coreRadius)
              core.addColorStop(0.0, 'rgba(255,255,255,0.35)')
              core.addColorStop(0.10, 'rgba(255,255,255,0.20)')
              core.addColorStop(0.25, 'rgba(255,255,255,0.08)')
              core.addColorStop(1.0, 'rgba(255,255,255,0.0)')
              spotCtx.fillStyle = core
              spotCtx.beginPath()
              spotCtx.arc(0, 0, coreRadius, 0, Math.PI * 2)
              spotCtx.fill()

              const spillRadius = Math.max(sRect.width, sRect.height) * 0.58
              spotCtx.globalAlpha = 0.7
              spotCtx.scale(0.95, 2.2)
              const spill = spotCtx.createRadialGradient(0, 0, 0, 0, 0, spillRadius)
              spill.addColorStop(0.0, 'rgba(255,255,255,0.09)')
              spill.addColorStop(0.20, 'rgba(255,255,255,0.045)')
              spill.addColorStop(1.0, 'rgba(255,255,255,0.0)')
              spotCtx.fillStyle = spill
              spotCtx.beginPath()
              spotCtx.arc(0, 0, spillRadius, 0, Math.PI * 2)
              spotCtx.fill()

              spotCtx.restore()
              requestAnimationFrame(animateSpotlight)
            }
            animateSpotlight()

            let ticking = false
            function onScroll() {
              if (!ticking) {
                window.requestAnimationFrame(() => {
                  const y = window.scrollY * 0.12
                  section.style.setProperty('--parallax', `${y}px`)
                  ticking = false
                })
                ticking = true
              }
            }
            window.addEventListener('scroll', onScroll, { passive: true })
            onScroll()

            const lazySections = document.querySelectorAll('.lazy-section')
            const io = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible')
                  io.unobserve(entry.target)
                }
              })
            }, { rootMargin: '0px 0px -10% 0px', threshold: 0.15 })

            lazySections.forEach((el) => io.observe(el))
        </script>

        <section class="hero-banner hero-secondary lazy-section">
            <div class="hero-content">
                <div class="hero-copy">
                    <p class="tag">Welcome back</p>
                    <h1 class="gradient-title">Hi <%= user.username %>, your English streak is alive.</h1>
                    <p>Keep growing your vocabulary, speaking confidence, and listening precision with a daily mix of live chat, drills, and AI feedback.</p>
                    <div class="hero-actions">
                        <a href="/chat" class="btn btn-primary">Jump into chat</a>
                        <a href="/progress" class="ghost-link">Review analytics</a>
                    </div>
                </div>
                <div class="stat-grid">
                    <div class="stat-card stat-3d">
                        <strong><%= stats.lessonsCompleted %></strong>
                        <span>Lessons completed</span>
                    </div>
                    <div class="stat-card stat-3d">
                        <strong><%= stats.studyTime %></strong>
                        <span>Active study time</span>
                    </div>
                    <div class="stat-card stat-3d">
                        <strong><%= stats.dayStreak %>���</strong>
                        <span>Day streak</span>
                    </div>
                    <div class="stat-card stat-3d">
                        <strong><%= stats.achievements %></strong>
                        <span>Milestones unlocked</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel panel-muted lazy-section">
            <h2>Today's focus</h2>
            <p class="muted">Pick a quick action to keep the momentum going.</p>
            <div class="card-grid" style="margin-top:1rem;">
                <a href="/chat" class="insight-card insight-muted">
                    <h3><i class="fas fa-comments"></i> Practice conversation</h3>
                    <p>10-minute guided dialogue with instant grammar cues.</p>
                </a>
                <a href="/voice" class="insight-card insight-muted">
                    <h3><i class="fas fa-microphone"></i> Voice lab</h3>
                    <p>Warm up with pronunciation drills and TTS playback.</p>
                </a>
                <a href="/vocabulary" class="insight-card insight-muted">
                    <h3><i class="fas fa-book"></i> Vocabulary builder</h3>
                    <p>Review saved words and unlock fresh phrases.</p>
                </a>
                <a href="/goals" class="insight-card insight-muted">
                    <h3><i class="fas fa-bullseye"></i> Learning goals</h3>
                    <p>Update targets and celebrate completed milestones.</p>
                </a>
                <a href="/progress" class="insight-card insight-muted">
                    <h3><i class="fas fa-chart-line"></i> Track progress</h3>
                    <p>See growth across speaking, listening, and vocabulary.</p>
                </a>
                <a href="/pronunciation" class="insight-card insight-muted">
                    <h3><i class="fas fa-volume-up"></i> Pronunciation coach</h3>
                    <p>Upload phrases and get phonetic corrections.</p>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
