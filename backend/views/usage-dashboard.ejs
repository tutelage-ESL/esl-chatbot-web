<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usage Dashboard - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <h1>ESL Academy</h1>
                <div class="academy-tagline">Excellence in English Learning</div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="usage-section" class="section active">
                <div class="usage-header">
                    <h2><i class="fas fa-chart-pie"></i> Usage Dashboard</h2>
                    <p class="usage-subtitle">Monitor your TTS usage and subscription benefits</p>
                </div>
                
                <div class="usage-container">
                    <!-- Current Subscription Card -->
                    <div class="usage-card subscription-card">
                        <div class="card-header">
                            <h3><i class="fas fa-crown"></i> Current Subscription</h3>
                            <div class="tier-badge" id="tier-badge">
                                <span id="current-tier">Loading...</span>
                            </div>
                        </div>
                        <div class="subscription-info">
                            <div class="tier-benefits" id="tier-benefits">
                                <div class="benefit-item">
                                    <i class="fas fa-clock"></i>
                                    <span id="monthly-limit">Loading...</span>
                                </div>
                                <div class="benefit-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Monthly reset</span>
                                </div>
                                <div class="benefit-item">
                                    <i class="fas fa-microphone"></i>
                                    <span>High-quality TTS</span>
                                </div>
                            </div>
                            <div class="upgrade-section">
                                <button class="btn btn-upgrade" onclick="showUpgradeModal()">
                                    <i class="fas fa-arrow-up"></i> Upgrade Plan
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Usage Statistics Card -->
                    <div class="usage-card stats-card">
                        <div class="card-header">
                            <h3><i class="fas fa-chart-bar"></i> This Month's Usage</h3>
                            <div class="usage-percentage" id="usage-percentage">0%</div>
                        </div>
                        <div class="usage-stats">
                            <div class="usage-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" id="progress-fill"></div>
                                </div>
                                <div class="usage-labels">
                                    <span id="used-time">0 min</span>
                                    <span id="total-time">0 min</span>
                                </div>
                            </div>
                            <div class="usage-details">
                                <div class="detail-item">
                                    <span class="detail-label">Remaining:</span>
                                    <span class="detail-value" id="remaining-time">0 min</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Last Reset:</span>
                                    <span class="detail-value" id="last-reset">-</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Next Reset:</span>
                                    <span class="detail-value" id="next-reset">-</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Usage Warnings Card -->
                    <div class="usage-card warnings-card" id="warnings-card" style="display: none;">
                        <div class="card-header">
                            <h3><i class="fas fa-exclamation-triangle"></i> Usage Alert</h3>
                        </div>
                        <div class="warning-content" id="warning-content">
                            <!-- Dynamic warning content -->
                        </div>
                    </div>

                    <!-- Quick Actions Card -->
                    <div class="usage-card actions-card">
                        <div class="card-header">
                            <h3><i class="fas fa-bolt"></i> Quick Actions</h3>
                        </div>
                        <div class="action-buttons">
                            <button class="action-btn" onclick="refreshUsage()">
                                <i class="fas fa-sync-alt"></i>
                                <span>Refresh Usage</span>
                            </button>
                            <button class="action-btn" onclick="viewHistory()">
                                <i class="fas fa-history"></i>
                                <span>View History</span>
                            </button>
                            <button class="action-btn" onclick="manageTier()">
                                <i class="fas fa-cog"></i>
                                <span>Manage Plan</span>
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Upgrade Modal -->
    <div id="upgrade-modal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Upgrade Your Plan</h3>
                <button class="modal-close" onclick="closeUpgradeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="tier-options">
                    <div class="tier-option" data-tier="Standard">
                        <div class="tier-name">Standard</div>
                        <div class="tier-limit">20 minutes/month</div>
                        <div class="tier-price">Free</div>
                        <button class="btn btn-select" onclick="selectTier('Standard')">Current Plan</button>
                    </div>
                    <div class="tier-option" data-tier="Gold">
                        <div class="tier-name">Gold</div>
                        <div class="tier-limit">60 minutes/month</div>
                        <div class="tier-price">$9.99/month</div>
                        <button class="btn btn-select" onclick="selectTier('Gold')">Select Gold</button>
                    </div>
                    <div class="tier-option" data-tier="Diamond">
                        <div class="tier-name">Diamond</div>
                        <div class="tier-limit">120 minutes/month</div>
                        <div class="tier-price">$19.99/month</div>
                        <button class="btn btn-select" onclick="selectTier('Diamond')">Select Diamond</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentUsageData = null;

        document.addEventListener('DOMContentLoaded', () => {
            loadUsageData();
            // Refresh usage data every 30 seconds
            setInterval(loadUsageData, 30000);
        });

        async function loadUsageData() {
            try {
                const response = await fetch('/api/subscription/status');
                if (!response.ok) {
                    throw new Error('Failed to fetch usage data');
                }
                
                currentUsageData = await response.json();
                updateUsageDisplay(currentUsageData);
            } catch (error) {
                console.error('Error loading usage data:', error);
                showError('Failed to load usage data');
            }
        }

        function updateUsageDisplay(data) {
            console.log('Usage data received:', data); // Debug log
            
            // Update tier information
            document.getElementById('current-tier').textContent = data.subscriptionTier || 'Standard';
            
            // Convert seconds to minutes for display
            const monthlyLimitMinutes = Math.floor((data.monthlyLimit || 0) / 60);
            const monthlyUsageMinutes = Math.floor((data.monthlyUsage || 0) / 60);
            const remainingUsageMinutes = Math.floor((data.remainingUsage || 0) / 60);
            
            document.getElementById('monthly-limit').textContent = `${monthlyLimitMinutes} minutes/month`;
            
            // Update tier badge styling
            const tierBadge = document.getElementById('tier-badge');
            tierBadge.className = `tier-badge tier-${(data.subscriptionTier || 'standard').toLowerCase()}`;
            
            // Update usage statistics with proper null checks
            const usagePercentage = data.usagePercentage || 0;
            document.getElementById('usage-percentage').textContent = `${usagePercentage}%`;
            document.getElementById('used-time').textContent = `${monthlyUsageMinutes} min`;
            document.getElementById('total-time').textContent = `${monthlyLimitMinutes} min`;
            document.getElementById('remaining-time').textContent = `${remainingUsageMinutes} min`;
            
            // Update progress bar
            const progressFill = document.getElementById('progress-fill');
            progressFill.style.width = `${usagePercentage}%`;
            progressFill.className = `progress-fill ${getProgressClass(usagePercentage)}`;
            
            // Update dates with proper null checks
            if (data.lastReset) {
                document.getElementById('last-reset').textContent = formatDate(data.lastReset);
                const nextReset = new Date(data.lastReset);
                nextReset.setMonth(nextReset.getMonth() + 1);
                document.getElementById('next-reset').textContent = formatDate(nextReset);
            } else {
                document.getElementById('last-reset').textContent = 'Not available';
                document.getElementById('next-reset').textContent = 'Not available';
            }
            
            // Show warnings if necessary
            updateWarnings(data);
        }

        function getProgressClass(percentage) {
            if (percentage >= 90) return 'critical';
            if (percentage >= 80) return 'warning';
            return 'normal';
        }

        function updateWarnings(data) {
            const warningsCard = document.getElementById('warnings-card');
            const warningContent = document.getElementById('warning-content');
            
            const usagePct = Math.round(data.usagePercentage || 0);
            const remainingMinutes = Math.max(0, Math.floor((data.remainingUsage || 0) / 60));
            
            if (data.nearLimit || usagePct >= 90) {
                let warningMessage = '';
                let warningClass = '';
                
                if (usagePct >= 95) {
                    warningMessage = `<strong>Critical:</strong> You've used ${usagePct}% of your monthly TTS quota. Consider upgrading your plan to avoid service interruption. You have ${remainingMinutes} minutes remaining.`;
                    warningClass = 'critical';
                } else if (usagePct >= 80) {
                    warningMessage = `<strong>Warning:</strong> You've used ${usagePct}% of your monthly TTS quota. You have ${remainingMinutes} minutes remaining.`;
                    warningClass = 'warning';
                }
                
                warningContent.innerHTML = `
                    <div class="warning-message ${warningClass}">
                        <i class="fas fa-exclamation-triangle"></i>
                        <p>${warningMessage}</p>
                        <button class="btn btn-upgrade-small" onclick="showUpgradeModal()">
                            Upgrade Now
                        </button>
                    </div>
                `;
                warningsCard.style.display = 'block';
            } else {
                warningsCard.style.display = 'none';
            }
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric' 
            });
        }

        function showUpgradeModal() {
            document.getElementById('upgrade-modal').style.display = 'flex';
            updateTierOptions();
        }

        function closeUpgradeModal() {
            document.getElementById('upgrade-modal').style.display = 'none';
        }

        function updateTierOptions() {
            const tierOptions = document.querySelectorAll('.tier-option');
            tierOptions.forEach(option => {
                const tier = option.dataset.tier;
                const button = option.querySelector('.btn-select');
                const normalizedCurrentTier = (currentUsageData?.subscriptionTier || 'standard').toLowerCase();
                
                if (tier.toLowerCase() === normalizedCurrentTier) {
                    button.textContent = 'Current Plan';
                    button.disabled = true;
                    option.classList.add('current');
                } else {
                    button.textContent = `Select ${tier}`;
                    button.disabled = false;
                    option.classList.remove('current');
                }
            });
        }

        async function selectTier(tier) {
            const normalizedCurrentTier = (currentUsageData?.subscriptionTier || '').toLowerCase();
            if (tier.toLowerCase() === normalizedCurrentTier) {
                return;
            }
            
            try {
                const response = await fetch('/api/subscription/tier', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ tier })
                });
                
                if (!response.ok) {
                    throw new Error('Failed to update tier');
                }
                
                const result = await response.json();
                showSuccess(`Successfully upgraded to ${tier} plan!`);
                closeUpgradeModal();
                loadUsageData(); // Refresh data
            } catch (error) {
                console.error('Error updating tier:', error);
                showError('Failed to update subscription tier');
            }
        }

        async function refreshUsage() {
            const button = event.target.closest('.action-btn');
            const icon = button.querySelector('i');
            
            icon.classList.add('fa-spin');
            await loadUsageData();
            
            setTimeout(() => {
                icon.classList.remove('fa-spin');
            }, 1000);
        }

        function viewHistory() {
            // Redirect to usage history page or show modal
            window.location.href = '/usage-history';
        }

        function manageTier() {
            showUpgradeModal();
        }

        function showSuccess(message) {
            // Simple success notification
            const notification = document.createElement('div');
            notification.className = 'notification success';
            notification.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        function showError(message) {
            // Simple error notification
            const notification = document.createElement('div');
            notification.className = 'notification error';
            notification.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${message}`;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('upgrade-modal');
            if (event.target === modal) {
                closeUpgradeModal();
            }
        }
    </script>
</body>
</html>