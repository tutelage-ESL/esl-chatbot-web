<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create account · ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>���</text></svg>">
</head>
<body class="brand-surface">
    <div class="auth-shell">
        <div class="auth-card" id="auth-container">
            <div class="brand-icon" style="margin:0 auto 1rem;"><img src="/brand-icons/ai-esl-logo.svg" alt="ESL Academy logo"></div>
            <h2>Join ESL Academy</h2>
            <p>Create your personalized AI-powered English workspace in seconds.</p>

            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                <div class="insight-card" style="border-color: #fecaca; background: #fff5f5;">
                    <% errors.forEach(function(error) { %>
                        <p style="margin:0; color:#b91c1c;"><%= error.msg %></p>
                    <% }); %>
                </div>
            <% } %>

            <form id="signup-form" action="/api/auth/signup" method="POST" class="form-stack">
                <div>
                    <label for="signup-username">Username</label>
                    <input type="text" id="signup-username" name="username" placeholder="Your name" value="<%= typeof oldInput !== 'undefined' ? oldInput.username : '' %>" required>
                </div>
                <div>
                    <label for="signup-email">Email address</label>
                    <input type="email" id="signup-email" name="email" placeholder="name@email.com" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
                </div>
                <div>
                    <label for="signup-password">Password</label>
                    <input type="password" id="signup-password" name="password" placeholder="Create a strong password" required>
                </div>

                <div>
                    <label for="subscription-tier">Choose your learning plan</label>
                    <select id="subscription-tier" name="subscriptionTier" required>
                        <option value="standard" <%= (typeof oldInput !== 'undefined' && oldInput.subscriptionTier === 'standard') ? 'selected' : '' %>>��� Standard · 20 min/month (Free)</option>
                        <option value="gold" <%= (typeof oldInput !== 'undefined' && oldInput.subscriptionTier === 'gold') ? 'selected' : '' %>>��� Gold · 1 hr/month ($9.99)</option>
                        <option value="diamond" <%= (typeof oldInput !== 'undefined' && oldInput.subscriptionTier === 'diamond') ? 'selected' : '' %>>��� Diamond · 2 hr/month ($19.99)</option>
                    </select>
                </div>

                <div class="tier-grid">
                    <div class="tier-card standard-benefit <%= (typeof oldInput === 'undefined' || oldInput.subscriptionTier === 'standard') ? 'active' : '' %>">
                        <h4>��� Standard plan</h4>
                        <ul>
                            <li>20 minutes of AI voice per month</li>
                            <li>Full chat + vocabulary access</li>
                            <li>Progress tracking</li>
                        </ul>
                    </div>
                    <div class="tier-card gold-benefit <%= (typeof oldInput !== 'undefined' && oldInput.subscriptionTier === 'gold') ? 'active' : '' %>">
                        <h4>��� Gold plan</h4>
                        <ul>
                            <li>1 hour of AI voice per month</li>
                            <li>Priority processing + drills</li>
                            <li>Advanced pronunciation feedback</li>
                        </ul>
                    </div>
                    <div class="tier-card diamond-benefit <%= (typeof oldInput !== 'undefined' && oldInput.subscriptionTier === 'diamond') ? 'active' : '' %>">
                        <h4>��� Diamond plan</h4>
                            <ul>
                                <li>2 hours of AI voice per month</li>
                                <li>Premium voice selection</li>
                                <li>Personalized learning paths</li>
                                <li>Priority support</li>
                            </ul>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">Create account</button>
            </form>

            <p style="margin-top:1.5rem;">Already a student? <a href="/login" class="link-muted">Sign in</a></p>
        </div>
    </div>

    <script>
        const tierSelect = document.getElementById('subscription-tier');
        const toggleBenefits = () => {
            ['standard', 'gold', 'diamond'].forEach(tier => {
                const card = document.querySelector(`.${tier}-benefit`);
                if (card) {
                    card.classList.toggle('active', tierSelect.value === tier);
                }
            });
        };
        tierSelect?.addEventListener('change', toggleBenefits);
        toggleBenefits();
    </script>
</body>
</html>
