<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Tutor - ESL Academy</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="stylesheet" href="/css/chat.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>">
 </head>

 <body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>

        <main class="page-shell">
            <section class="hero-banner">
                <div class="hero-content">
                    <div class="hero-copy">
                        <p class="tag">Tutor</p>
                        <h1><i class="fas fa-robot"></i> AI English Tutor</h1>
                        <p>Converse naturally and improve fluency with guided feedback.</p>
                    </div>
                </div>
            </section>
            <section class="chat-shell">
              <!-- Left: Chat -->
              <div id="chat-section" class="chat-panel soft-shadow rounded-xl border border-border">
                <div class="chat-header">
                  <div class="tutor-profile">
                    <div class="avatar"><i class="fas fa-robot"></i></div>
                    <div class="info">
                      <h3>AI English Tutor</h3>
                      <span class="status"><i class="fas fa-circle"></i> Online & Ready</span>
                    </div>
                  </div>
                  <div class="chat-actions">
                    <div class="tts-usage-display" id="tts-usage-display">
                      <i class="fas fa-volume-up"></i>
                      <span id="tts-remaining">Loading...</span>
                      <small>TTS remaining</small>
                    </div>
                    <button id="voice-settings-btn" class="icon-btn" type="button" title="Voice Settings" aria-label="Voice Settings" aria-controls="voice-settings-panel" aria-expanded="false">
                      <i class="fas fa-cog"></i>
                    </button>
                    <button id="download-chat" class="icon-btn" type="button" title="Download Transcript" aria-label="Download Transcript">
                      <i class="fas fa-download"></i>
                    </button>
                    <button id="clear-chat" class="icon-btn danger" type="button" title="Clear Chat" aria-label="Clear Chat">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </div>
                </div>

                <!-- Conversation mode chips -->
                <div class="quick-suggestions" aria-label="Conversation modes">
                  <button class="quick-chip suggestion-btn" data-text="Practice conversation">Conversation</button>
                  <button class="quick-chip suggestion-btn" data-text="Help me with grammar">Grammar</button>
                  <button class="quick-chip suggestion-btn" data-text="Explain vocabulary">Vocabulary</button>
                  <button class="quick-chip suggestion-btn" data-text="Check pronunciation">Pronunciation</button>
                </div>

                <div class="chat-container chat-stream">
                  <div class="chat-messages" id="chat-messages" role="log" aria-live="polite" aria-relevant="additions text" aria-atomic="false" aria-label="Chat messages">
                    <!-- Connection status indicator -->
                    <div class="connection-status" id="connection-status">
                      <i class="fas fa-circle"></i>
                      <span>Connecting...</span>
                    </div>
                    <!-- Messages will be dynamically added here -->
                  </div>
                  <!-- typing indicator appended via JS -->
                </div>

                <div id="chat-input-container" class="input-bar">
                  <div class="input-pill">
                    <i class="fas fa-comment-dots"></i>
                    <textarea id="chat-input" rows="1" placeholder="Ask anything about English…" aria-label="Message input" aria-multiline="true"></textarea>
                    <div class="actions">
                      <button id="voice-btn" class="icon-btn primary" type="button" title="Voice Input" aria-label="Voice Input">
                        <i class="fas fa-microphone"></i>
                      </button>
                      <button id="send-btn" class="icon-btn primary" type="button" title="Send Message" aria-label="Send Message">
                        <i class="fas fa-paper-plane"></i>
                      </button>
                    </div>
                  </div>
                  <div class="voice-status" id="voice-status-mini">Ready</div>

                  <!-- Voice Settings Panel -->
                  <div class="voice-settings-panel" id="voice-settings-panel" style="display: none;">
                    <div class="settings-content">
                      <h6><i class="fas fa-volume-up"></i> Voice Settings</h6>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="auto-speak-chat" checked>
                        <label class="form-check-label" for="auto-speak-chat">
                          Auto-speak AI responses
                          <small id="auto-speak-indicator-chat"> (Enabled)</small>
                        </label>
                      </div>
                      <div class="form-group">
                        <label for="voice-speed-chat">Speech Speed:</label>
                        <input type="range" id="voice-speed-chat" min="0.5" max="2" step="0.1" value="1">
                        <small>Speed: <span id="speed-value-chat">1.0</span>x</small>
                      </div>
                      <div class="form-group">
                        <label for="tts-provider">TTS Provider:</label>
                        <select id="tts-provider" class="form-select">
                          <option value="auto" selected>Auto (ElevenLabs → Browser)</option>
                         <option value="elevenlabs">ElevenLabs</option>
                          <option value="google">Google TTS (Free)</option>
                          <option value="piper">Free HQ (Piper)</option>
                          <option value="browser">Browser TTS</option>
                        </select>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="enable-tts-chat" checked>
                        <label class="form-check-label" for="enable-tts-chat">Enable TTS</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="free-tts-only">
                        <label class="form-check-label" for="free-tts-only">Use free TTS only</label>
                      </div>
                      <div class="form-group">
                        <button type="button" id="test-voice-chat" class="btn btn-primary w-full">
                          <i class="fas fa-volume-up"></i> Test Voice
                        </button>
                      </div>
                      <div class="form-group">
                        <button type="button" id="stop-voice-chat" class="btn btn-secondary w-full">
                          <i class="fas fa-stop"></i> Stop
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Tips panel removed to expand chat -->
            </section>
        </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/app.js?v=<%= Date.now() %>"></script>
</body>

</html>
