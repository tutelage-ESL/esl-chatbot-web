<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pronunciation Practice - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .pronunciation-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }
        .pronunciation-header {
            text-align: center;
            margin-bottom: 40px;
        }
        .pronunciation-header h2 {
            color: #333;
            margin-bottom: 10px;
        }
        .pronunciation-header p {
            color: #666;
            font-size: 1.1em;
        }
        .practice-section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .word-input-section {
            margin-bottom: 30px;
        }

        .difficulty-selector {
            margin-bottom: 25px;
            text-align: center;
        }

        .difficulty-selector label {
            display: block;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 10px;
            font-size: 1.1em;
        }

        .difficulty-selector select {
            padding: 12px 20px;
            border: 2px solid #e1e8ed;
            border-radius: 10px;
            font-size: 1em;
            background: white;
            color: #2c3e50;
            cursor: pointer;
            transition: all 0.3s ease;
            min-width: 250px;
        }

        .difficulty-selector select:hover {
            border-color: #3498db;
        }

        .difficulty-selector select:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
        }
        .input-group {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }
        .word-input {
            flex: 1;
            padding: 15px;
            border: 2px solid #e1e5e9;
            border-radius: 10px;
            font-size: 16px;
            transition: border-color 0.3s;
        }
        .word-input:focus {
            outline: none;
            border-color: #667eea;
        }
        .practice-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 25px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .practice-btn:hover {
            transform: translateY(-2px);
        }
        .practice-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
        .current-word {
            text-align: center;
            margin-bottom: 30px;
        }
        .word-display {
            font-size: 3em;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
        }
        .phonetic-display {
            font-size: 1.5em;
            color: #666;
            font-style: italic;
            margin-bottom: 20px;
        }
        .recording-section {
            text-align: center;
            margin-bottom: 30px;
        }
        .record-btn {
            background: #dc3545;
            color: white;
            border: none;
            padding: 20px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.5em;
            transition: all 0.3s;
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        .record-btn:hover {
            background: #c82333;
            transform: scale(1.1);
        }
        .record-btn.recording {
            background: #28a745;
            animation: pulse 1s infinite;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        .recording-status {
            font-size: 1.1em;
            color: #666;
            margin-bottom: 15px;
        }
        .recording-timer {
            font-size: 1.2em;
            font-weight: bold;
            color: #dc3545;
        }
        .analysis-section {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-top: 30px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            display: none;
        }

        .loading {
            text-align: center;
            padding: 40px;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .error {
            text-align: center;
            padding: 20px;
            color: #e74c3c;
        }

        .error-details {
            font-size: 0.9em;
            color: #7f8c8d;
            margin-top: 10px;
        }

        .analysis-title {
            font-size: 1.5em;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 25px;
            text-align: center;
        }

        .score-display {
            display: flex;
            justify-content: space-around;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .score-item {
            text-align: center;
            flex: 1;
            min-width: 120px;
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            border: 2px solid transparent;
            transition: all 0.3s ease;
        }

        .score-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .score-value {
            font-size: 2.2em;
            font-weight: bold;
            display: block;
            margin-bottom: 8px;
        }

        .score-label {
            font-size: 0.9em;
            color: #7f8c8d;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .excellent { 
            color: #27ae60;
        }
        .good { 
            color: #f39c12;
        }
        .fair {
            color: #e67e22;
        }
        .needs-work { 
            color: #e74c3c;
        }

        .feedback-text {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            line-height: 1.6;
            border-left: 4px solid #3498db;
        }

        .feedback-text ul {
            margin: 10px 0;
            padding-left: 20px;
        }

        .feedback-text li {
            margin-bottom: 8px;
            color: #2c3e50;
        }

        .transcription-section {
            background: #e8f4fd;
            border: 2px solid #3498db;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            text-align: center;
        }

        .transcription-title {
            font-size: 1.1em;
            font-weight: 600;
            color: #2980b9;
            margin-bottom: 15px;
        }

        .transcription-text {
            font-size: 1.3em;
            font-weight: bold;
            color: #2c3e50;
            background: white;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-style: italic;
            border: 1px solid #bdc3c7;
        }

        .target-word {
            font-size: 1em;
            color: #7f8c8d;
        }

        .target-word strong {
            color: #2980b9;
            font-size: 1.1em;
        }

        .difficulty-badge {
            text-align: center;
            margin-bottom: 20px;
        }

        .difficulty {
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .difficulty.beginner {
            background: #d5f4e6;
            color: #27ae60;
        }

        .difficulty.intermediate {
            background: #fef9e7;
            color: #f39c12;
        }

        .difficulty.advanced {
            background: #fadbd8;
            color: #e74c3c;
        }
        .try-again-btn {
            background: #28a745;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background 0.3s;
        }
        .try-again-btn:hover {
            background: #218838;
        }
        .practice-history {
            margin-top: 40px;
        }
        .history-title {
            font-size: 1.3em;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .history-list {
            display: grid;
            gap: 15px;
        }
        .history-item {
            background: white;
            padding: 20px;
            border-radius: 10px;
            border: 1px solid #e1e5e9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .history-word {
            font-weight: bold;
            color: #333;
        }
        .history-score {
            color: #667eea;
            font-weight: 600;
        }
        .history-date {
            color: #888;
            font-size: 0.9em;
        }
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #666;
        }
        .empty-state i {
            font-size: 3em;
            margin-bottom: 15px;
            color: #ddd;
        }
        .quick-words {
            margin-bottom: 20px;
        }
        .quick-words-title {
            font-size: 1.1em;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }
        .quick-word-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .quick-word-btn {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 8px 15px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 14px;
        }
        .quick-word-btn:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
    </style>
 </head>
 <body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>
    <section class="hero-banner">
        <div class="hero-content">
            <div class="hero-copy">
                <p class="tag">Pronunciation</p>
                <h1>Practice clear, confident speech.</h1>
                <p>Work on tricky sounds with instant feedback and tips.</p>
            </div>
        </div>
    </section>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <h1>ESL Academy</h1>
                <div class="academy-tagline">Excellence in English Learning</div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <div class="pronunciation-container">
                <div class="pronunciation-header">
                    <h2><i class="fas fa-microphone"></i> Pronunciation Practice</h2>
                    <p>Improve your English pronunciation with AI-powered feedback</p>
                </div>

                <div class="practice-section">
                    <div class="word-input-section">
                        <div class="difficulty-selector">
                            <label for="difficultySelect">Difficulty Level:</label>
                            <select id="difficultySelect" onchange="changeDifficulty()">
                                <option value="beginner">Beginner (Simple words)</option>
                                <option value="intermediate" selected>Intermediate (Common words)</option>
                                <option value="advanced">Advanced (Complex words)</option>
                            </select>
                        </div>
                        
                        <div class="quick-words">
                            <div class="quick-words-title">Quick Practice Words:</div>
                            <div class="quick-word-buttons">
                                <button class="quick-word-btn" onclick="setWord('hello')">hello</button>
                                <button class="quick-word-btn" onclick="setWord('world')">world</button>
                                <button class="quick-word-btn" onclick="setWord('beautiful')">beautiful</button>
                                <button class="quick-word-btn" onclick="setWord('pronunciation')">pronunciation</button>
                                <button class="quick-word-btn" onclick="setWord('communication')">communication</button>
                                <button class="quick-word-btn" onclick="setWord('opportunity')">opportunity</button>
                                <button class="quick-word-btn" onclick="setWord('responsibility')">responsibility</button>
                            </div>
                        </div>
                        
                        <div class="input-group">
                            <input type="text" id="wordInput" class="word-input" placeholder="Enter a word to practice..." value="">
                            <button id="generateBtn" onclick="generateNewWord()">🎲 Random Word</button>
                            <button id="startPracticeBtn" class="practice-btn" onclick="startPractice()">
                                <i class="fas fa-play"></i> Start Practice
                            </button>
                        </div>
                    </div>

                    <div id="practiceArea" style="display: none;">
                        <div class="current-word">
                            <div id="wordDisplay" class="word-display"></div>
                            <div id="phoneticDisplay" class="phonetic-display"></div>
                        </div>

                        <div class="recording-section">
                            <button id="recordBtn" class="record-btn" onclick="toggleRecording()">
                                <i class="fas fa-microphone"></i>
                            </button>
                            <div id="recordingStatus" class="recording-status">Click to start recording</div>
                            <div id="recordingTimer" class="recording-timer" style="display: none;">0s</div>
                        </div>

                        <div id="analysisSection" class="analysis-section">
                            <div class="analysis-title">
                                <i class="fas fa-chart-line"></i> Pronunciation Analysis
                            </div>
                            
                            <div class="score-display">
                                <div class="score-item">
                                    <span id="accuracyScore" class="score-value">--</span>
                                    <div class="score-label">Accuracy</div>
                                </div>
                                <div class="score-item">
                                    <span id="fluencyScore" class="score-value">--</span>
                                    <div class="score-label">Fluency</div>
                                </div>
                                <div class="score-item">
                                    <span id="overallScore" class="score-value">--</span>
                                    <div class="score-label">Overall</div>
                                </div>
                            </div>
                            
                            <div id="feedbackText" class="feedback-text"></div>
                            
                            <button class="try-again-btn" onclick="resetPractice()">
                                <i class="fas fa-redo"></i> Try Again
                            </button>
                        </div>
                    </div>
                </div>

                <div class="practice-history">
                    <div class="history-title">
                        <i class="fas fa-history"></i> Practice History
                    </div>
                    
                    <div id="historyList" class="history-list">
                        <div class="empty-state">
                            <i class="fas fa-microphone-slash"></i>
                            <h3>No practice history</h3>
                            <p>Start practicing to see your progress here!</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        let isRecording = false;
        let recordingTimer = null;
        let recordingTime = 0;
        let mediaRecorder = null;
        let audioChunks = [];
        let currentWord = '';

        function setWord(word) {
            document.getElementById('wordInput').value = word;
        }

        function startPractice() {
            const word = document.getElementById('wordInput').value.trim();
            if (!word) {
                alert('Please enter a word to practice.');
                return;
            }
            
            currentWord = word;
            document.getElementById('wordDisplay').textContent = word;
            document.getElementById('phoneticDisplay').textContent = `/${word}/`; // Simplified phonetic
            document.getElementById('practiceArea').style.display = 'block';
            document.getElementById('analysisSection').style.display = 'none';
            resetRecording();
        }

        async function toggleRecording() {
            if (!isRecording) {
                await startRecording();
            } else {
                stopRecording();
            }
        }

        async function startRecording() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                
                mediaRecorder.ondataavailable = (event) => {
                    audioChunks.push(event.data);
                };
                
                mediaRecorder.onstop = () => {
                    const audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
                    analyzePronunciation(audioBlob);
                };
                
                mediaRecorder.start();
                isRecording = true;
                recordingTime = 0;
                
                document.getElementById('recordBtn').classList.add('recording');
                document.getElementById('recordBtn').innerHTML = '<i class="fas fa-stop"></i>';
                document.getElementById('recordingStatus').textContent = 'Recording... Click to stop';
                document.getElementById('recordingTimer').style.display = 'block';
                
                recordingTimer = setInterval(() => {
                    recordingTime++;
                    document.getElementById('recordingTimer').textContent = recordingTime + 's';
                }, 1000);
                
            } catch (error) {
                console.error('Error accessing microphone:', error);
                alert('Unable to access microphone. Please check your permissions.');
            }
        }

        function stopRecording() {
            if (mediaRecorder && isRecording) {
                mediaRecorder.stop();
                mediaRecorder.stream.getTracks().forEach(track => track.stop());
                isRecording = false;
                
                clearInterval(recordingTimer);
                
                document.getElementById('recordBtn').classList.remove('recording');
                document.getElementById('recordBtn').innerHTML = '<i class="fas fa-microphone"></i>';
                document.getElementById('recordingStatus').textContent = 'Analyzing pronunciation...';
                document.getElementById('recordingTimer').style.display = 'none';
            }
        }

        async function analyzePronunciation(audioBlob) {
            // Show loading state
            const analysisSection = document.getElementById('analysisSection');
            analysisSection.style.display = 'block';
            analysisSection.innerHTML = `
                <div class="loading">
                    <div class="spinner"></div>
                    <p>Analyzing your pronunciation...</p>
                </div>
            `;

            try {
                const formData = new FormData();
                formData.append('audio', audioBlob, 'recording.wav');
                formData.append('word', currentWord);
                
                const response = await fetch('/api/pronunciation/analyze', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                if (data.success) {
                    displayAnalysis(data);
                    addToHistory(currentWord, data.overall);
                } else {
                    throw new Error(data.error || 'Analysis failed');
                }
            } catch (error) {
                console.error('Error:', error);
                analysisSection.innerHTML = `
                    <div class="error">
                        <p>❌ Analysis failed. Please try again.</p>
                        <p class="error-details">${error.message}</p>
                    </div>
                `;
            }
        }

        function displayAnalysis(analysis) {
            const analysisSection = document.getElementById('analysisSection');
            analysisSection.style.display = 'block';
            
            // Create comprehensive analysis display
            analysisSection.innerHTML = `
                <div class="analysis-title">
                    <i class="fas fa-chart-line"></i> Pronunciation Analysis
                </div>
                
                ${analysis.transcription ? `
                    <div class="transcription-section">
                        <div class="transcription-title">
                            <i class="fas fa-quote-left"></i> What we heard:
                        </div>
                        <div class="transcription-text">
                            "${analysis.transcription}"
                        </div>
                        <div class="target-word">
                            Target word: <strong>${currentWord}</strong>
                        </div>
                    </div>
                ` : ''}
                
                <div class="score-display">
                    <div class="score-item">
                        <span class="score-value ${getScoreClass(analysis.accuracy)}">${analysis.accuracy}%</span>
                        <div class="score-label">Accuracy</div>
                    </div>
                    <div class="score-item">
                        <span class="score-value ${getScoreClass(analysis.fluency)}">${analysis.fluency}%</span>
                        <div class="score-label">Fluency</div>
                    </div>
                    <div class="score-item">
                        <span class="score-value ${getScoreClass(analysis.overall)}">${analysis.overall}%</span>
                        <div class="score-label">Overall</div>
                    </div>
                </div>
                
                <div class="feedback-text">
                    <strong>📝 Feedback:</strong><br>
                    ${analysis.feedback}
                </div>
                
                ${analysis.suggestions && analysis.suggestions.length > 0 ? `
                    <div class="feedback-text">
                        <strong>💡 Improvement Suggestions:</strong>
                        <ul>
                            ${analysis.suggestions.map(suggestion => `<li>${suggestion}</li>`).join('')}
                        </ul>
                    </div>
                ` : ''}
                
                ${analysis.phoneticTips && analysis.phoneticTips.length > 0 ? `
                    <div class="feedback-text">
                        <strong>🗣️ Phonetic Tips:</strong>
                        <ul>
                            ${analysis.phoneticTips.map(tip => `<li>${tip}</li>`).join('')}
                        </ul>
                    </div>
                ` : ''}
                
                <button class="try-again-btn" onclick="resetPractice()">
                    <i class="fas fa-redo"></i> Try Again
                </button>
            `;
            
            document.getElementById('recordingStatus').textContent = 'Analysis complete!';
            
            // Add to history
            addToHistory(currentWord, analysis.overall);
        }
        
        function getScoreClass(score) {
            if (score >= 90) return 'excellent';
            if (score >= 75) return 'good';
            if (score >= 60) return 'fair';
            return 'needs-work';
        }

        function addToHistory(word, score) {
            const historyList = document.getElementById('historyList');
            
            // Remove empty state if it exists
            const emptyState = historyList.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            const historyItem = document.createElement('div');
            historyItem.className = 'history-item';
            historyItem.innerHTML = `
                <div>
                    <div class="history-word">${word}</div>
                    <div class="history-date">${new Date().toLocaleDateString()}</div>
                </div>
                <div class="history-score">${score}%</div>
            `;
            
            historyList.insertBefore(historyItem, historyList.firstChild);
        }

        function resetPractice() {
            resetRecording();
            document.getElementById('analysisSection').style.display = 'none';
        }

        function resetRecording() {
            isRecording = false;
            clearInterval(recordingTimer);
            recordingTime = 0;
            
            document.getElementById('recordBtn').classList.remove('recording');
            document.getElementById('recordBtn').innerHTML = '<i class="fas fa-microphone"></i>';
            document.getElementById('recordingStatus').textContent = 'Click to start recording';
            document.getElementById('recordingTimer').style.display = 'none';
        }

        function generateNewWord() {
            const practiceWords = {
                beginner: ['cat', 'dog', 'book', 'pen', 'red', 'big', 'yes', 'no', 'sun', 'car', 'tree', 'house', 'water', 'food', 'happy'],
                intermediate: ['beautiful', 'important', 'different', 'interesting', 'comfortable', 'wonderful', 'education', 'computer', 'telephone', 'restaurant', 'hospital', 'university', 'government', 'environment', 'technology'],
                advanced: ['pronunciation', 'communication', 'responsibility', 'characteristics', 'unfortunately', 'administration', 'representative', 'international', 'organization', 'development', 'implementation', 'extraordinary', 'pharmaceutical', 'entrepreneurship', 'incomprehensible']
            };
            
            const currentDifficulty = document.getElementById('difficultySelect')?.value || 'intermediate';
            const words = practiceWords[currentDifficulty];
            const randomWord = words[Math.floor(Math.random() * words.length)];
            
            document.getElementById('wordInput').value = randomWord;
            currentWord = randomWord;
            resetPractice();
        }

        // Add difficulty selector functionality
        function changeDifficulty() {
            generateNewWord();
        }

        // Allow Enter key to start practice
        document.getElementById('wordInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                startPractice();
            }
        });
    </script>
</body>
</html>