<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - ESL Learning Chatbot</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">
</head>
<body>
    <div id="auth-container">
        <div id="login-form-container">
            <div class="auth-logo">
                🎓
            </div>
            <h2>Welcome Back</h2>
            <p class="auth-subtitle">Sign in to continue your English learning journey</p>
            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                <div class="error-messages">
                    <% errors.forEach(function(error) { %>
                        <p style="color: #ef4444; margin: 0.5rem 0; font-size: 0.9rem;"><%= error.msg %></p>
                    <% }); %>
                </div>
            <% } %>
            <form id="login-form" action="/api/auth/login" method="POST">
                <input type="email" id="login-email" name="email" placeholder="📧 Email Address" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
                <input type="password" id="login-password" name="password" placeholder="🔒 Password" required>
                <button type="submit">Sign In to Academy</button>
            </form>
            <p>New to ESL Academy? <a href="/signup" id="show-signup">Create Account</a></p>
        </div>
    </div>


    
</body>
</html>