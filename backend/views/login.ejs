<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in ¬∑ ESL Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>ŪīĖ</text></svg>">
</head>
<body class="brand-surface">
    <div class="auth-shell">
        <div class="auth-card" id="auth-container">
            <div class="brand-icon" style="margin:0 auto 1rem;">Ūĺď</div>
            <h2>Welcome back</h2>
            <p>Sign in to continue your personalized English learning journey.</p>

            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                <div class="insight-card" style="border-color: #fecaca; background: #fff5f5;">
                    <% errors.forEach(function(error) { %>
                        <p style="margin:0; color:#b91c1c;"><%= error.msg %></p>
                    <% }); %>
                </div>
            <% } %>

            <form id="login-form" action="/api/auth/login" method="POST" class="form-stack">
                <div>
                    <label for="login-email">Email address</label>
                    <input type="email" id="login-email" name="email" placeholder="name@email.com" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
                </div>
                <div>
                    <label for="login-password">Password</label>
                    <input type="password" id="login-password" name="password" placeholder="‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ" required>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">Sign in</button>
            </form>

            <p style="margin-top:1.5rem;">New to ESL Academy? <a href="/signup" class="link-muted">Create an account</a></p>
        </div>
    </div>
</body>
</html>
