<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Goals - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand-app.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .goals-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .goals-header {
            text-align: center;
            margin-bottom: 40px;
        }
        .goals-header h2 {
            color: #333;
            margin-bottom: 10px;
        }
        .goals-header p {
            color: #666;
            font-size: 1.1em;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .stat-card h3 {
            font-size: 2rem;
            margin-bottom: 5px;
        }
        .stat-card p {
            opacity: 0.9;
            font-size: 0.9rem;
        }
        .tabs {
            display: flex;
            margin-bottom: 30px;
            border-bottom: 2px solid #f0f0f0;
        }
        .tab {
            padding: 15px 25px;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            color: #666;
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
        }
        .tab.active {
            color: #667eea;
            border-bottom-color: #667eea;
            font-weight: 600;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .goals-section {
            margin-bottom: 40px;
        }
        .section-title {
            font-size: 1.5em;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .add-goal-form {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
        }
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        .form-group label {
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
        }
        .form-group input, .form-group select, .form-group textarea {
            padding: 12px;
            border: 2px solid #e1e5e9;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
        }
        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }
        .goal-type-selector {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }
        .goal-type-option {
            padding: 15px;
            border: 2px solid #e1e5e9;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .goal-type-option:hover {
            border-color: #667eea;
            background: #f8f9ff;
        }
        .goal-type-option.selected {
            border-color: #667eea;
            background: #667eea;
            color: white;
        }
        .goal-type-option i {
            font-size: 1.5em;
            margin-bottom: 8px;
            display: block;
        }
        .create-goal-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.2s;
            width: 100%;
        }
        .create-goal-btn:hover {
            transform: translateY(-2px);
        }
        .goals-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        .goal-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .goal-card:hover {
            transform: translateY(-5px);
        }
        .goal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }
        .goal-title {
            font-size: 1.2em;
            font-weight: bold;
            color: #333;
            margin-bottom: 5px;
        }
        .goal-type-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: 600;
            text-transform: capitalize;
        }
        .goal-type-daily { background: #d4edda; color: #155724; }
        .goal-type-weekly { background: #cce5ff; color: #004085; }
        .goal-type-monthly { background: #fff3cd; color: #856404; }
        .goal-type-custom { background: #f8d7da; color: #721c24; }
        .goal-description {
            color: #666;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .goal-progress {
            margin-bottom: 15px;
        }
        .progress-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e1e5e9;
            border-radius: 4px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s;
        }
        .goal-deadline {
            font-size: 0.9em;
            color: #888;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }
        .empty-state i {
            font-size: 4em;
            margin-bottom: 20px;
            color: #ddd;
        }
        .completed-goal {
            opacity: 0.7;
            border: 2px solid #28a745;
        }
        .completed-badge {
            background: #28a745;
            color: white;
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: 600;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .btn-secondary {
            background: #6c757d;
        }
        
        .btn-danger {
            background: #dc3545;
        }
        
        .btn-small {
            padding: 8px 16px;
            font-size: 0.9rem;
            margin: 0 5px;
        }
        
        .goal-type {
            display: inline-block;
            padding: 4px 12px;
            background: #667eea;
            color: white;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: capitalize;
            margin-bottom: 10px;
        }
        
        .status-paused {
            background: #fff3e0;
            color: #f57c00;
        }
        
        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        
        .progress-label {
            font-weight: 500;
            color: #333;
        }
        
        .progress-percentage {
            font-weight: 600;
            color: #667eea;
        }
        
        .milestones {
            margin-bottom: 20px;
        }
        
        .milestone {
            display: flex;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .milestone:last-child {
            border-bottom: none;
        }
        
        .milestone-icon {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            margin-right: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
        }
        
        .milestone-completed {
            background: #4caf50;
            color: white;
        }
        
        .milestone-pending {
            background: #e0e0e0;
            color: #666;
        }
        
        .milestone-text {
            flex: 1;
            font-size: 0.9rem;
            color: #666;
        }
        
        .milestone-completed .milestone-text {
            color: #333;
            font-weight: 500;
        }
        
        .meta-item {
            display: flex;
            flex-direction: column;
        }
        
        .meta-label {
            font-weight: 500;
            color: #333;
            margin-bottom: 2px;
        }
        
        .goal-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .streak-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: #ff9800;
            color: white;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        
        .suggestions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .suggestion-card {
            background: #f8f9fa;
            border: 2px dashed #dee2e6;
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .suggestion-card:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }
        
        .suggestion-title {
            font-size: 1.2rem;
            color: #333;
            margin-bottom: 10px;
            font-weight: 600;
        }
        
        .suggestion-description {
            color: #666;
            margin-bottom: 15px;
            line-height: 1.5;
        }
        
        .suggestion-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            color: #888;
            margin-bottom: 15px;
        }
        
        .suggestion-reason {
            font-style: italic;
            color: #667eea;
            font-size: 0.9rem;
        }
        
        .loading {
            text-align: center;
            padding: 40px;
            color: #666;
        }
        
        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #667eea;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }
            
            .goals-grid {
                grid-template-columns: 1fr;
            }
            
            .goal-meta {
                grid-template-columns: 1fr;
            }
        }
    </style>
 </head>
 <body class="brand-surface">
    <%- include('partials/nav', { currentRoute: currentRoute }) %>
    <section class="hero-banner">
        <div class="hero-content">
            <div class="hero-copy">
                <p class="tag">Goals</p>
                <h1>Set targets. Track progress.</h1>
                <p>Define learning goals and keep your streak on track.</p>
            </div>
        </div>
    </section>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <h1>ESL Academy</h1>
                <div class="academy-tagline">Excellence in English Learning</div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <div class="goals-container">
                <div class="goals-header">
                    <h2><i class="fas fa-target"></i> Learning Goals</h2>
                    <p>Set, track, and achieve your English learning objectives</p>
                </div>

                <!-- Statistics Section -->
                <div id="statsSection" class="stats-grid">
                    <div class="stat-card">
                        <h3 id="totalGoals">0</h3>
                        <p>Total Goals</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="activeGoals">0</h3>
                        <p>Active Goals</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="completedGoals">0</h3>
                        <p>Completed Goals</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="completionRate">0%</h3>
                        <p>Completion Rate</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="averageProgress">0%</h3>
                        <p>Average Progress</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="bestStreak">0</h3>
                        <p>Best Streak</p>
                    </div>
                </div>
                
                <!-- Tabs Navigation -->
                <div class="tabs">
                    <button class="tab active" onclick="showTab('active')">Active Goals</button>
                    <button class="tab" onclick="showTab('completed')">Completed</button>
                    <button class="tab" onclick="showTab('add')">Add Goal</button>
                    <button class="tab" onclick="showTab('suggestions')">Suggestions</button>
                </div>
                
                <!-- Active Goals Tab -->
                <div id="activeTab" class="tab-content active">
                    <div id="activeGoalsList" class="goals-grid">
                        <!-- Active goals will be loaded here -->
                    </div>
                    <div id="activeGoalsEmpty" class="empty-state" style="display: none;">
                        <h3>No Active Goals</h3>
                        <p>Start by setting your first learning goal!</p>
                        <button class="btn" onclick="showTab('add')">Add Your First Goal</button>
                    </div>
                </div>
                
                <!-- Completed Goals Tab -->
                <div id="completedTab" class="tab-content">
                    <div id="completedGoalsList" class="goals-grid">
                        <!-- Completed goals will be loaded here -->
                    </div>
                    <div id="completedGoalsEmpty" class="empty-state" style="display: none;">
                        <h3>No Completed Goals Yet</h3>
                        <p>Keep working on your active goals to see them here!</p>
                    </div>
                </div>
                
                <!-- Add Goal Tab -->
                <div id="addTab" class="tab-content">
                    <div class="add-goal-form">
                        <h2>Set a New Learning Goal</h2>
                        <form id="goalForm">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="goalType">Goal Type:</label>
                                    <select id="goalType" required>
                                        <option value="">Select goal type</option>
                                        <option value="vocabulary">Vocabulary Building</option>
                                        <option value="pronunciation">Pronunciation Practice</option>
                                        <option value="conversation">Conversation Skills</option>
                                    </select>
                                </div>
                                
                                <div class="form-group">
                                    <label for="goalTimeframe">Timeframe:</label>
                                    <select id="goalTimeframe" required>
                                        <option value="">Select timeframe</option>
                                        <option value="week">1 Week</option>
                                        <option value="month">1 Month</option>
                                        <option value="quarter">3 Months</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="goalTarget">Target (number):</label>
                                    <input type="number" id="goalTarget" min="1" max="1000" required placeholder="e.g., 50 words">
                                </div>
                                
                                <div class="form-group">
                                    <label for="goalDifficulty">Difficulty:</label>
                                    <select id="goalDifficulty">
                                        <option value="">Auto-detect</option>
                                        <option value="beginner">Beginner</option>
                                        <option value="intermediate">Intermediate</option>
                                        <option value="advanced">Advanced</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label for="goalDescription">Custom Description (optional):</label>
                                <textarea id="goalDescription" rows="3" placeholder="Describe your specific learning objective..."></textarea>
                            </div>
                            
                            <button type="submit" class="btn">Create Goal</button>
                        </form>
                    </div>
                </div>
                
                <!-- Suggestions Tab -->
                <div id="suggestionsTab" class="tab-content">
                    <h2>Recommended Goals</h2>
                    <p style="margin-bottom: 30px; color: #666;">Based on your learning progress, here are some goals we recommend:</p>
                    <div id="suggestionsList" class="suggestions-grid">
                        <!-- Suggestions will be loaded here -->
                    </div>
                    <div id="suggestionsLoading" class="loading">
                        <div class="spinner"></div>
                        <p>Loading personalized suggestions...</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        let currentGoals = [];
        let currentStats = {};
        let currentSuggestions = [];
        
        // Initialize the page
        document.addEventListener('DOMContentLoaded', function() {
            loadGoals();
            loadSuggestions();
        });
        
        // Tab switching functionality
        function showTab(tabName) {
            // Remove active class from all tabs and content
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            
            // Add active class to clicked tab and corresponding content
            event.target.classList.add('active');
            document.getElementById(tabName + 'Tab').classList.add('active');
            
            // Load suggestions when suggestions tab is opened
            if (tabName === 'suggestions') {
                loadSuggestions();
            }
        }
        
        // Load goals and statistics
        async function loadGoals() {
            try {
                const response = await fetch('/api/goals');
                const data = await response.json();
                
                if (data.goals) {
                    currentGoals = data.goals;
                    currentStats = data.stats || {};
                    
                    updateStatistics();
                    renderActiveGoals();
                    renderCompletedGoals();
                }
            } catch (error) {
                console.error('Error loading goals:', error);
            }
        }
        
        // Update statistics display
        function updateStatistics() {
            document.getElementById('totalGoals').textContent = currentStats.total || 0;
            document.getElementById('activeGoals').textContent = currentStats.active || 0;
            document.getElementById('completedGoals').textContent = currentStats.completed || 0;
            document.getElementById('completionRate').textContent = (currentStats.completionRate || 0) + '%';
            document.getElementById('averageProgress').textContent = (currentStats.averageProgress || 0) + '%';
            document.getElementById('bestStreak').textContent = currentStats.bestStreak || 0;
        }
        
        // Render active goals
        function renderActiveGoals() {
            const activeGoals = currentGoals.filter(goal => goal.status === 'active');
            const container = document.getElementById('activeGoalsList');
            const emptyState = document.getElementById('activeGoalsEmpty');
            
            if (activeGoals.length === 0) {
                container.innerHTML = '';
                emptyState.style.display = 'block';
                return;
            }
            
            emptyState.style.display = 'none';
            container.innerHTML = activeGoals.map(goal => createGoalCard(goal)).join('');
        }
        
        // Render completed goals
        function renderCompletedGoals() {
            const completedGoals = currentGoals.filter(goal => goal.status === 'completed');
            const container = document.getElementById('completedGoalsList');
            const emptyState = document.getElementById('completedGoalsEmpty');
            
            if (completedGoals.length === 0) {
                container.innerHTML = '';
                emptyState.style.display = 'block';
                return;
            }
            
            emptyState.style.display = 'none';
            container.innerHTML = completedGoals.map(goal => createGoalCard(goal)).join('');
        }
        
        // Create goal card HTML
        function createGoalCard(goal) {
            const progress = goal.progress || 0;
            const streak = goal.currentStreak || 0;
            const milestones = goal.milestones || [];
            const completedMilestones = goal.completedMilestones || 0;
            
            const milestonesHtml = milestones.map((milestone, index) => {
                const isCompleted = index < completedMilestones;
                return `
                    <div class="milestone">
                        <div class="milestone-icon ${isCompleted ? 'milestone-completed' : 'milestone-pending'}">
                            ${isCompleted ? '✓' : (index + 1)}
                        </div>
                        <div class="milestone-text ${isCompleted ? 'milestone-completed' : ''}">
                            ${milestone.title}
                        </div>
                    </div>
                `;
            }).join('');
            
            const actionPlan = goal.actionPlan || [];
            const actionPlanHtml = actionPlan.map(action => `<li>${action}</li>`).join('');
            
            return `
                <div class="goal-card">
                    ${streak > 0 ? `<div class="streak-badge">${streak} day streak</div>` : ''}
                    
                    <div class="goal-header">
                        <div>
                            <div class="goal-type">${goal.type}</div>
                            <div class="goal-title">${goal.description}</div>
                        </div>
                        <div class="goal-status status-${goal.status}">${goal.status}</div>
                    </div>
                    
                    <div class="goal-progress">
                        <div class="progress-header">
                            <span class="progress-label">Progress</span>
                            <span class="progress-percentage">${Math.round(progress)}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${progress}%"></div>
                        </div>
                    </div>
                    
                    ${milestones.length > 0 ? `
                        <div class="milestones">
                            <h4 style="margin-bottom: 10px; color: #333;">Milestones</h4>
                            ${milestonesHtml}
                        </div>
                    ` : ''}
                    
                    <div class="goal-meta">
                        <div class="meta-item">
                            <span class="meta-label">Target</span>
                            <span>${goal.target} ${goal.type === 'vocabulary' ? 'words' : goal.type === 'pronunciation' ? 'words' : 'conversations'}</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Timeframe</span>
                            <span>${goal.timeframe}</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Difficulty</span>
                            <span style="text-transform: capitalize;">${goal.difficulty || 'intermediate'}</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Created</span>
                            <span>${new Date(goal.createdAt).toLocaleDateString()}</span>
                        </div>
                    </div>
                    
                    ${actionPlan.length > 0 ? `
                        <div style="margin-bottom: 20px;">
                            <h4 style="margin-bottom: 10px; color: #333;">Action Plan</h4>
                            <ul style="margin-left: 20px; color: #666;">
                                ${actionPlanHtml}
                            </ul>
                        </div>
                    ` : ''}
                    
                    <div class="goal-actions">
                        ${goal.status === 'active' ? `
                            <button class="btn btn-small" onclick="recordProgress(${goal.id})">Record Progress</button>
                            <button class="btn btn-secondary btn-small" onclick="editGoal(${goal.id})">Edit</button>
                        ` : ''}
                        <button class="btn btn-danger btn-small" onclick="deleteGoal(${goal.id})">Delete</button>
                    </div>
                </div>
            `;
        }
        
        // Goal form submission
        document.getElementById('goalForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = {
                type: document.getElementById('goalType').value,
                target: parseInt(document.getElementById('goalTarget').value),
                timeframe: document.getElementById('goalTimeframe').value,
                description: document.getElementById('goalDescription').value,
                difficulty: document.getElementById('goalDifficulty').value
            };
            
            try {
                const response = await fetch('/api/goals', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('Goal created successfully!');
                    document.getElementById('goalForm').reset();
                    loadGoals();
                    showTab('active');
                } else {
                    alert('Error creating goal: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error creating goal');
            }
        });
        
        // Record progress for a goal
        async function recordProgress(goalId) {
            const activity = prompt('What activity did you complete?', 'Practice session');
            if (!activity) return;
            
            const value = prompt('How much progress? (e.g., 1 for one word, 5 for five words)', '1');
            if (!value) return;
            
            try {
                const response = await fetch(`/api/goals/${goalId}/progress`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        activity,
                        value: parseInt(value)
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    let message = `Progress recorded! ${result.progress}% complete`;
                    if (result.milestoneCompleted) {
                        message += '\n🎉 Milestone completed!';
                    }
                    if (result.goalCompleted) {
                        message += '\n🏆 Goal completed! Congratulations!';
                    }
                    alert(message);
                    loadGoals();
                } else {
                    alert('Error recording progress: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error recording progress');
            }
        }
        
        // Edit goal
        async function editGoal(goalId) {
            const goal = currentGoals.find(g => g.id === goalId);
            if (!goal) return;
            
            const newDescription = prompt('Edit goal description:', goal.description);
            if (newDescription === null) return;
            
            try {
                const response = await fetch(`/api/goals/${goalId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        description: newDescription
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('Goal updated successfully!');
                    loadGoals();
                } else {
                    alert('Error updating goal: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error updating goal');
            }
        }
        
        // Delete goal
        async function deleteGoal(goalId) {
            if (!confirm('Are you sure you want to delete this goal?')) return;
            
            try {
                const response = await fetch(`/api/goals/${goalId}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('Goal deleted successfully!');
                    loadGoals();
                } else {
                    alert('Error deleting goal: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error deleting goal');
            }
        }
        
        // Load goal suggestions
        async function loadSuggestions() {
            const loadingElement = document.getElementById('suggestionsLoading');
            const listElement = document.getElementById('suggestionsList');
            
            loadingElement.style.display = 'block';
            listElement.innerHTML = '';
            
            try {
                const response = await fetch('/api/goals/suggestions');
                const data = await response.json();
                
                loadingElement.style.display = 'none';
                
                if (data.suggestions && data.suggestions.length > 0) {
                    currentSuggestions = data.suggestions;
                    renderSuggestions();
                } else {
                    listElement.innerHTML = '<div class="empty-state"><h3>No suggestions available</h3><p>Complete some activities to get personalized goal suggestions!</p></div>';
                }
            } catch (error) {
                console.error('Error loading suggestions:', error);
                loadingElement.style.display = 'none';
                listElement.innerHTML = '<div class="empty-state"><h3>Error loading suggestions</h3><p>Please try again later.</p></div>';
            }
        }
        
        // Render goal suggestions
        function renderSuggestions() {
            const container = document.getElementById('suggestionsList');
            
            container.innerHTML = currentSuggestions.map(suggestion => `
                <div class="suggestion-card" onclick="createSuggestedGoal('${suggestion.type}', ${suggestion.target}, '${suggestion.timeframe}', '${suggestion.description}', '${suggestion.difficulty}')">
                    <div class="suggestion-title">${suggestion.title}</div>
                    <div class="suggestion-description">${suggestion.description}</div>
                    <div class="suggestion-meta">
                        <span>Target: ${suggestion.target}</span>
                        <span>Timeframe: ${suggestion.timeframe}</span>
                        <span>Difficulty: ${suggestion.difficulty}</span>
                    </div>
                    <div class="suggestion-reason">${suggestion.reason}</div>
                </div>
            `).join('');
        }
        
        // Create goal from suggestion
        async function createSuggestedGoal(type, target, timeframe, description, difficulty) {
            if (!confirm(`Create this goal: ${description}?`)) return;
            
            try {
                const response = await fetch('/api/goals', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        type,
                        target,
                        timeframe,
                        description,
                        difficulty
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('Goal created successfully!');
                    loadGoals();
                    showTab('active');
                } else {
                    alert('Error creating goal: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error creating goal');
            }
        }
    </script>
</body>
</html>