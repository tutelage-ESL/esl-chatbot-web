{
  "name": "esl-chatbot-backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "infisical run --env=dev -- bun --watch src/index.ts",
    "start": "infisical run --env=prod -- bun src/index.ts",
    "dev:env": "bun --watch src/index.ts",
    "start:env": "bun src/index.ts",
    "db:generate": "bunx prisma generate",
    "db:migrate": "infisical run --env=dev -- bunx prisma migrate dev",
    "db:push": "infisical run --env=dev -- bunx prisma db push",
    "db:seed": "infisical run --env=dev -- bun prisma/seed.ts",
    "db:studio": "infisical run --env=dev -- bunx prisma studio",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "bun scripts/export-openapi.ts",
    "generate:types": "bun run generate:openapi && bunx openapi-typescript openapi.json -o ../frontend/types/api.ts",
    "test": "infisical run --env=dev -- bun test",
    "test:watch": "infisical run --env=dev -- bun test --watch"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.11",
    "openapi-typescript": "^7.13.0",
    "prisma": "6",
    "supertest": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.3.0",
    "@google/genai": "^1.50.1",
    "@prisma/client": "6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "morgan": "^1.10.1",
    "msedge-tts": "^2.0.5",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "resend": "^6.12.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
