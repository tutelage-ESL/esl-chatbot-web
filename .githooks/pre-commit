#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────────
# esl-chatbot-web pre-commit hook
#
# Runs ONLY when backend/ files are staged:
#   1. backend typecheck  (tsc --noEmit)        — catches type errors before commit
#   2. frontend/types/api.ts sync check         — ensures the generated API types
#      were regenerated after a backend route/schema change
#
# Enable once per clone:   git config core.hooksPath .githooks
# (the backend "prepare" script runs this automatically on `bun install`)
# ─────────────────────────────────────────────────────────────────────────────

ROOT="$(git rev-parse --show-toplevel)"

# Skip entirely unless backend code is part of this commit.
if ! git diff --cached --name-only | grep -q '^backend/'; then
  exit 0
fi

# The checks need Bun. If it's missing, warn but don't block the commit.
if ! command -v bun >/dev/null 2>&1; then
  echo "⚠ pre-commit: 'bun' not found on PATH — skipping typecheck / api.ts sync check."
  exit 0
fi

cd "$ROOT/backend" || exit 1

# ── 1. Typecheck ────────────────────────────────────────────────────────────
echo "▶ pre-commit: backend typecheck…"
if ! bun run typecheck; then
  echo ""
  echo "✗ pre-commit: typecheck failed — fix the type errors above before committing."
  exit 1
fi

# ── 2. Generated API types in sync ───────────────────────────────────────────
echo "▶ pre-commit: verifying frontend/types/api.ts is in sync with Swagger…"
bun run generate:types >/dev/null 2>&1
if ! git -C "$ROOT" diff --quiet -- frontend/types/api.ts; then
  echo ""
  echo "✗ pre-commit: frontend/types/api.ts was out of date with the backend Swagger spec."
  echo "  It has just been regenerated for you. Stage it and commit again:"
  echo ""
  echo "      git add frontend/types/api.ts"
  echo ""
  exit 1
fi

echo "✓ pre-commit: checks passed."
exit 0
