<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - ESL Learning Chatbot</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">
</head>
<body>
    <div id="auth-container">
        <div id="signup-form-container">
            <h2>Sign Up</h2>
            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                <div class="error-messages">
                    <% errors.forEach(function(error) { %>
                        <p><%= error.msg %></p>
                    <% }); %>
                </div>
            <% } %>
            <form id="signup-form" action="/api/auth/signup" method="POST">
                <input type="text" id="signup-username" name="username" placeholder="Username" value="<%= typeof oldInput !== 'undefined' ? oldInput.username : '' %>" required>
                <input type="email" id="signup-email" name="email" placeholder="Email" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
                <input type="password" id="signup-password" name="password" placeholder="Password" required>
                <button type="submit">Sign Up</button>
            </form>
            <p>Already have an account? <a href="/login" id="show-login">Log in</a></p>
        </div>
    </div>


    
</body>
</html>