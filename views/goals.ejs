<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning Goals - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .goals-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .goals-header {
            text-align: center;
            margin-bottom: 40px;
        }
        .goals-header h2 {
            color: #333;
            margin-bottom: 10px;
        }
        .goals-header p {
            color: #666;
            font-size: 1.1em;
        }
        .goals-section {
            margin-bottom: 40px;
        }
        .section-title {
            font-size: 1.5em;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .add-goal-form {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
        }
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        .form-group label {
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
        }
        .form-group input, .form-group select, .form-group textarea {
            padding: 12px;
            border: 2px solid #e1e5e9;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
        }
        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }
        .goal-type-selector {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }
        .goal-type-option {
            padding: 15px;
            border: 2px solid #e1e5e9;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .goal-type-option:hover {
            border-color: #667eea;
            background: #f8f9ff;
        }
        .goal-type-option.selected {
            border-color: #667eea;
            background: #667eea;
            color: white;
        }
        .goal-type-option i {
            font-size: 1.5em;
            margin-bottom: 8px;
            display: block;
        }
        .create-goal-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.2s;
            width: 100%;
        }
        .create-goal-btn:hover {
            transform: translateY(-2px);
        }
        .goals-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        .goal-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .goal-card:hover {
            transform: translateY(-5px);
        }
        .goal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }
        .goal-title {
            font-size: 1.2em;
            font-weight: bold;
            color: #333;
            margin-bottom: 5px;
        }
        .goal-type-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: 600;
            text-transform: capitalize;
        }
        .goal-type-daily { background: #d4edda; color: #155724; }
        .goal-type-weekly { background: #cce5ff; color: #004085; }
        .goal-type-monthly { background: #fff3cd; color: #856404; }
        .goal-type-custom { background: #f8d7da; color: #721c24; }
        .goal-description {
            color: #666;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .goal-progress {
            margin-bottom: 15px;
        }
        .progress-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e1e5e9;
            border-radius: 4px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s;
        }
        .goal-deadline {
            font-size: 0.9em;
            color: #888;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }
        .empty-state i {
            font-size: 4em;
            margin-bottom: 20px;
            color: #ddd;
        }
        .completed-goal {
            opacity: 0.7;
            border: 2px solid #28a745;
        }
        .completed-badge {
            background: #28a745;
            color: white;
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <h1>ESL Academy</h1>
                <div class="academy-tagline">Excellence in English Learning</div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <div class="goals-container">
                <div class="goals-header">
                    <h2><i class="fas fa-target"></i> Learning Goals</h2>
                    <p>Set and track your English learning objectives</p>
                </div>

                <!-- Add New Goal Form -->
                <div class="add-goal-form">
                    <h3><i class="fas fa-plus"></i> Create New Goal</h3>
                    <form id="addGoalForm">
                        <div class="goal-type-selector">
                            <div class="goal-type-option" data-type="daily">
                                <i class="fas fa-calendar-day"></i>
                                <div>Daily</div>
                            </div>
                            <div class="goal-type-option" data-type="weekly">
                                <i class="fas fa-calendar-week"></i>
                                <div>Weekly</div>
                            </div>
                            <div class="goal-type-option" data-type="monthly">
                                <i class="fas fa-calendar-alt"></i>
                                <div>Monthly</div>
                            </div>
                            <div class="goal-type-option" data-type="custom">
                                <i class="fas fa-cog"></i>
                                <div>Custom</div>
                            </div>
                        </div>
                        
                        <input type="hidden" id="goalType" name="type" value="">
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="target">Target (Number)</label>
                                <input type="number" id="target" name="target" required placeholder="e.g., 10" min="1">
                            </div>
                            <div class="form-group">
                                <label for="deadline">Deadline (Optional)</label>
                                <input type="date" id="deadline" name="deadline">
                            </div>
                        </div>
                        
                        <div class="form-group full-width">
                            <label for="description">Goal Description</label>
                            <textarea id="description" name="description" required placeholder="Describe your learning goal..."></textarea>
                        </div>
                        
                        <button type="submit" class="create-goal-btn">
                            <i class="fas fa-target"></i> Create Goal
                        </button>
                    </form>
                </div>

                <!-- Active Goals -->
                <div class="goals-section">
                    <h3 class="section-title">
                        <i class="fas fa-play"></i> Active Goals
                    </h3>
                    
                    <% if (goals.activeGoals && goals.activeGoals.length > 0) { %>
                        <div class="goals-grid">
                            <% goals.activeGoals.forEach(goal => { %>
                                <div class="goal-card">
                                    <div class="goal-header">
                                        <div>
                                            <div class="goal-title"><%= goal.description %></div>
                                        </div>
                                        <div class="goal-type-badge goal-type-<%= goal.type %>">
                                            <%= goal.type %>
                                        </div>
                                    </div>
                                    
                                    <div class="goal-progress">
                                        <div class="progress-info">
                                            <span>Progress</span>
                                            <span><%= goal.current %>/<%= goal.target %></span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: <%= Math.min(100, (goal.current / goal.target) * 100) %>%;"></div>
                                        </div>
                                    </div>
                                    
                                    <% if (goal.deadline) { %>
                                        <div class="goal-deadline">
                                            <i class="fas fa-calendar"></i>
                                            Due: <%= new Date(goal.deadline).toLocaleDateString() %>
                                        </div>
                                    <% } %>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-target"></i>
                            <h3>No active goals</h3>
                            <p>Create your first learning goal to start tracking your progress!</p>
                        </div>
                    <% } %>
                </div>

                <!-- Completed Goals -->
                <% if (goals.completedGoals && goals.completedGoals.length > 0) { %>
                    <div class="goals-section">
                        <h3 class="section-title">
                            <i class="fas fa-check"></i> Completed Goals
                        </h3>
                        
                        <div class="goals-grid">
                            <% goals.completedGoals.forEach(goal => { %>
                                <div class="goal-card completed-goal">
                                    <div class="goal-header">
                                        <div>
                                            <div class="goal-title"><%= goal.description %></div>
                                        </div>
                                        <div class="completed-badge">
                                            <i class="fas fa-check"></i> Completed
                                        </div>
                                    </div>
                                    
                                    <div class="goal-progress">
                                        <div class="progress-info">
                                            <span>Completed</span>
                                            <span><%= goal.target %>/<%= goal.target %></span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: 100%;"></div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        // Goal type selection
        document.querySelectorAll('.goal-type-option').forEach(option => {
            option.addEventListener('click', () => {
                document.querySelectorAll('.goal-type-option').forEach(opt => opt.classList.remove('selected'));
                option.classList.add('selected');
                document.getElementById('goalType').value = option.dataset.type;
            });
        });

        // Form submission
        document.getElementById('addGoalForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const goalData = {
                type: formData.get('type'),
                target: parseInt(formData.get('target')),
                deadline: formData.get('deadline') || null,
                description: formData.get('description')
            };
            
            if (!goalData.type) {
                alert('Please select a goal type.');
                return;
            }
            
            try {
                const response = await fetch('/api/goals/set', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(goalData)
                });
                
                if (response.ok) {
                    location.reload(); // Refresh to show new goal
                } else {
                    alert('Failed to create goal. Please try again.');
                }
            } catch (error) {
                console.error('Error creating goal:', error);
                alert('Failed to create goal. Please try again.');
            }
        });
    </script>
</body>
</html>