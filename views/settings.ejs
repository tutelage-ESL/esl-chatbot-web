<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Settings</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="settings-section" class="section active">
                <div class="settings-container">
                <h2>Settings</h2>
                <form id="settings-form" class="settings-form" action="/settings" method="post">
                    <div class="form-group">
                        <label for="language-select">Language:</label>
                        <select id="language-select" name="language">
  <option value="en" <%= settings.language === 'en' ? 'selected' : '' %>>English</option>
  <option value="es" <%= settings.language === 'es' ? 'selected' : '' %>>Spanish</option>
  <option value="fr" <%= settings.language === 'fr' ? 'selected' : '' %>>French</option>

                            <!-- Add more languages as needed -->
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="voice-speed">Voice Speed:</label>
                        <input type="range" id="voice-speed" name="voiceSpeed" min="0.5" max="2" step="0.1" value="<%= settings.voiceSpeed %>">
                        <span id="speed-value"><%= settings.voiceSpeed %>x</span>
                    </div>
                    <div class="form-group checkbox-group">
                        <input type="checkbox" id="auto-speak" name="autoSpeak" <%= settings.autoSpeak ? 'checked' : '' %>>
                        <label for="auto-speak">Auto-speak Bot Responses</label>
                    </div>
                    <button type="submit">Save Settings</button>
                </form>
                </div>
            </section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const voiceSpeedInput = document.getElementById('voice-speed');
        const speedValueSpan = document.getElementById('speed-value');

        // Initialize display
        speedValueSpan.textContent = voiceSpeedInput.value + 'x';

        // Update display on slider change
        voiceSpeedInput.addEventListener('input', () => {
            speedValueSpan.textContent = voiceSpeedInput.value + 'x';
        });
    });
</script>
        </main>
    </div>

    
</body>
</html>