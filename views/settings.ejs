<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Settings</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <nav class="app-nav">
                <button class="nav-btn" data-route="chat">
                    <i class="fas fa-comments"></i>
                    <span>Chat</span>
                </button>
                <button class="nav-btn" data-route="voice">
                    <i class="fas fa-microphone"></i>
                    <span>Voice</span>
                </button>
                <button class="nav-btn" data-route="progress">
                    <i class="fas fa-chart-line"></i>
                    <span>Progress</span>
                </button>
                <button class="nav-btn active" data-route="settings">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </button>
                <button id="logout-btn" class="nav-btn">Logout</button>
            </nav>
        </header>

        <main class="app-main">
            <section id="settings-section" class="section active">
                <h2>Settings</h2>
                <form id="settings-form" class="settings-form">
                    <div class="form-group">
                        <label for="language-select">Language:</label>
                        <select id="language-select">
                            <option value="en">English</option>
                            <option value="es">Spanish</option>
                            <option value="fr">French</option>
                            <!-- Add more languages as needed -->
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="voice-speed">Voice Speed:</label>
                        <input type="range" id="voice-speed" min="0.5" max="2" step="0.1" value="1">
                        <span id="speed-value">1x</span>
                    </div>
                    <div class="form-group checkbox-group">
                        <input type="checkbox" id="auto-speak">
                        <label for="auto-speak">Auto-speak Bot Responses</label>
                    </div>
                    <button type="submit">Save Settings</button>
                </form>
            </section>
        </main>
    </div>

    <script>
        const SUPABASE_URL = "<%= SUPABASE_URL %>";
        const SUPABASE_ANON_KEY = "<%= SUPABASE_ANON_KEY %>";
    </script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="/js/app.js" defer></script>
</body>
</html>