<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vocabulary Builder - ESL Academy</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .vocabulary-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .vocab-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .vocab-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .vocab-stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
        }
        .vocab-stat-number {
            font-size: 2.5em;
            font-weight: bold;
            margin-bottom: 5px;
        }
        .vocab-stat-label {
            font-size: 0.9em;
            opacity: 0.9;
        }
        .add-word-form {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
        }
        .form-group label {
            margin-bottom: 5px;
            font-weight: 600;
            color: #333;
        }
        .form-group input, .form-group select, .form-group textarea {
            padding: 10px;
            border: 2px solid #e1e5e9;
            border-radius: 8px;
            font-size: 14px;
        }
        .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }
        .add-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: transform 0.2s;
        }
        .add-btn:hover {
            transform: translateY(-2px);
        }
        .words-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .word-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .word-card:hover {
            transform: translateY(-5px);
        }
        .word-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .word-title {
            font-size: 1.4em;
            font-weight: bold;
            color: #333;
        }
        .difficulty-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: 600;
        }
        .difficulty-easy { background: #d4edda; color: #155724; }
        .difficulty-medium { background: #fff3cd; color: #856404; }
        .difficulty-hard { background: #f8d7da; color: #721c24; }
        .word-definition {
            color: #666;
            margin-bottom: 10px;
            line-height: 1.5;
        }
        .word-example {
            font-style: italic;
            color: #888;
            background: #f8f9fa;
            padding: 10px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }
        .empty-state i {
            font-size: 4em;
            margin-bottom: 20px;
            color: #ddd;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <h1>ESL Academy</h1>
                <div class="academy-tagline">Excellence in English Learning</div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <div class="vocabulary-container">
                <div class="vocab-header">
                    <div>
                        <h2><i class="fas fa-book"></i> Vocabulary Builder</h2>
                        <p>Build and track your English vocabulary</p>
                    </div>
                </div>

                <!-- Vocabulary Statistics -->
                <div class="vocab-stats">
                    <div class="vocab-stat-card">
                        <div class="vocab-stat-number"><%= vocabulary.totalWords %></div>
                        <div class="vocab-stat-label">Total Words</div>
                    </div>
                    <div class="vocab-stat-card">
                        <div class="vocab-stat-number"><%= vocabulary.masteredWords %></div>
                        <div class="vocab-stat-label">Mastered Words</div>
                    </div>
                    <div class="vocab-stat-card">
                        <div class="vocab-stat-number"><%= vocabulary.totalWords > 0 ? Math.round((vocabulary.masteredWords / vocabulary.totalWords) * 100) : 0 %>%</div>
                        <div class="vocab-stat-label">Mastery Rate</div>
                    </div>
                </div>

                <!-- Add New Word Form -->
                <div class="add-word-form">
                    <h3><i class="fas fa-plus"></i> Add New Word</h3>
                    <form id="addWordForm">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="word">Word</label>
                                <input type="text" id="word" name="word" required placeholder="Enter new word">
                            </div>
                            <div class="form-group">
                                <label for="definition">Definition</label>
                                <textarea id="definition" name="definition" required placeholder="Enter definition"></textarea>
                            </div>
                            <div class="form-group">
                                <label for="difficulty">Difficulty</label>
                                <select id="difficulty" name="difficulty">
                                    <option value="beginner" selected>Beginner</option>
                                    <option value="intermediate">Intermediate</option>
                                    <option value="advanced">Advanced</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="example">Example Sentence</label>
                            <textarea id="example" name="example" placeholder="Enter an example sentence using this word"></textarea>
                        </div>
                        <button type="submit" class="add-btn">
                            <i class="fas fa-plus"></i> Add Word
                        </button>
                    </form>
                </div>

                <!-- Words List -->
                <% if (vocabulary.words && vocabulary.words.length > 0) { %>
                    <div class="words-grid" id="wordsGrid">
                        <% vocabulary.words.forEach(word => { %>
                            <div class="word-card">
                                <div class="word-header">
                                    <div class="word-title"><%= word.word %></div>
                                    <div class="difficulty-badge difficulty-<%= word.difficulty %>">
                                        <%= word.difficulty %>
                                    </div>
                                </div>
                                <div class="word-definition"><%= word.definition %></div>
                                <% if (word.example) { %>
                                    <div class="word-example">
                                        "<%= word.example %>"
                                    </div>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-book-open"></i>
                        <h3>No words yet!</h3>
                        <p>Start building your vocabulary by adding your first word above.</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        document.getElementById('addWordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const wordData = {
                word: formData.get('word'),
                definition: formData.get('definition'),
                example: formData.get('example'),
                difficulty: formData.get('difficulty')
            };
            
            try {
                const response = await fetch('/api/vocabulary/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(wordData)
                });
                
                if (response.ok) {
                    location.reload(); // Refresh to show new word
                } else {
                    alert('Failed to add word. Please try again.');
                }
            } catch (error) {
                console.error('Error adding word:', error);
                alert('Failed to add word. Please try again.');
            }
        });
    </script>
</body>
</html>