<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Voice</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="voice-section" class="section active">
  <h2>Voice Interaction (Text Simulation)</h2>
  <form action="/voice" method="post">
    <textarea name="message" placeholder="Type your spoken message here..."></textarea>
    <button type="submit">Send</button>
  </form>
  <% if (response) { %>
    <div class="voice-output">
      <p>Assistant: <%= response %></p>
    </div>
  <% } %>
</section>
        </main>
    </div>

    
</body>
</html>