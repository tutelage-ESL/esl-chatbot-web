<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Voice</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="voice-section" class="section active">
                <div class="voice-container">
                    <div class="voice-header">
                        <h2><i class="fas fa-microphone"></i> Voice Learning Assistant</h2>
                        <p class="voice-description">Practice your English speaking skills with our AI tutor. Click "Start Speaking" and have a natural conversation!</p>
                    </div>
                    
                    <div class="voice-status-container">
                        <div id="voice-status" class="voice-status ready">Ready to listen</div>
                    </div>
                    
                    <div class="voice-controls">
                        <button id="start-recognition" class="voice-btn primary">
                            <i class="fas fa-microphone"></i> Start Speaking
                        </button>
                        <button id="stop-recognition" class="voice-btn secondary" disabled>
                            <i class="fas fa-stop"></i> Stop Speaking
                        </button>
                        <button id="test-api" class="btn btn-warning" style="margin-left: 10px;">
                            <i class="fas fa-test-tube"></i> Test API
                        </button>
                    </div>
                    
                    <div class="voice-settings" style="margin-top: 15px; padding: 10px; background-color: #f8f9fa; border-radius: 5px;">
                        <h5><i class="fas fa-cog"></i> Voice Settings</h5>
                        <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="auto-speak" checked>
                    <label class="form-check-label" for="auto-speak">
                        <i class="fas fa-volume-up"></i> Auto-speak AI responses
                        <small class="text-success" id="auto-speak-indicator"> (Enabled)</small>
                    </label>
                </div>
                        <div class="form-group" style="margin-top: 10px;">
                            <label for="voice-speed">Speech Speed:</label>
                            <input type="range" id="voice-speed" min="0.5" max="2" step="0.1" value="1" class="form-control-range">
                            <small class="form-text text-muted">Speed: <span id="speed-value">1.0</span>x</small>
                        </div>
                        <div class="form-group" style="margin-top: 10px;">
                            <button type="button" id="test-voice" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-volume-up"></i> Test Voice
                            </button>
                        </div>
                    </div>
                    
                    <div class="voice-output">
                        <div class="voice-section">
                            <div class="section-header">
                                <i class="fas fa-user"></i>
                                <h3>You said:</h3>
                            </div>
                            <div class="text-display user-text">
                                <p id="recognized-text" class="voice-text">Your speech will appear here...</p>
                            </div>
                        </div>
                        
                        <div class="voice-section">
                            <div class="section-header">
                                <i class="fas fa-robot"></i>
                                <h3>Assistant:</h3>
                                <button id="speak-response-btn" class="speak-btn" style="display: none;">
                                    <i class="fas fa-volume-up"></i> Speak Response
                                </button>
                            </div>
                            <div class="text-display assistant-text">
                                <p id="assistant-response" class="voice-text">AI response will appear here...</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="voice-tips">
                        <h4><i class="fas fa-lightbulb"></i> Tips for better voice recognition:</h4>
                        <ul>
                            <li>Speak clearly and at a normal pace</li>
                            <li>Ensure you're in a quiet environment</li>
                            <li>Allow microphone access when prompted</li>
                            <li>Wait for the "Listening..." status before speaking</li>
                            <li>Speak for at least 2-3 seconds to avoid detection issues</li>
                            <li>If you get "No speech detected", try speaking louder or closer to the microphone</li>
                            <li>Make sure no other applications are using your microphone</li>
                        </ul>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/js/voice.js"></script>
</body>
</html>