<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Chat</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="chat-section" class="section active">
                <div class="chat-container">
                    <div class="chat-messages" id="chat-messages">
                        <!-- Connection status indicator -->
                        <div class="connection-status" id="connection-status">
                            <i class="fas fa-circle"></i>
                            <span>Connecting...</span>
                        </div>
                        <!-- Messages will be dynamically added here -->
                    </div>
                    <div class="chat-input-container" id="chat-input-container">
                        <div class="voice-controls-mini">
                            <button id="voice-input-btn" type="button" class="voice-btn" title="Voice Input">
                                <i class="fas fa-microphone"></i>
                            </button>
                            <div class="voice-status-mini" id="voice-status-mini">Ready</div>
                        </div>
                        <textarea id="chat-input" placeholder="Type your message here... (Press Enter to send, or use voice input)" rows="1"></textarea>
                        <div class="chat-actions">
                            <button id="voice-settings-toggle" type="button" class="settings-btn" title="Voice Settings">
                                <i class="fas fa-cog"></i>
                            </button>
                            <button id="send-btn" type="button" disabled>
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Voice Settings Panel -->
                    <div class="voice-settings-panel" id="voice-settings-panel" style="display: none;">
                        <div class="settings-content">
                            <h6><i class="fas fa-volume-up"></i> Voice Settings</h6>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="auto-speak-chat" checked>
                                <label class="form-check-label" for="auto-speak-chat">
                                    Auto-speak AI responses
                                    <small class="text-success" id="auto-speak-indicator-chat"> (Enabled)</small>
                                </label>
                            </div>
                            <div class="form-group" style="margin-top: 10px;">
                                <label for="voice-speed-chat">Speech Speed:</label>
                                <input type="range" id="voice-speed-chat" min="0.5" max="2" step="0.1" value="1" class="form-control-range">
                                <small class="form-text text-muted">Speed: <span id="speed-value-chat">1.0</span>x</small>
                            </div>
                            <div class="form-group" style="margin-top: 10px;">
                                <button type="button" id="test-voice-chat" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-volume-up"></i> Test Voice
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>