<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Tutor - ESL Academy</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="academy-brand">
                <div class="academy-logo">🎓</div>
                <div>
                    <h1>ESL Academy</h1>
                    <p class="academy-tagline">Master English with AI-Powered Learning</p>
                </div>
            </div>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="chat-section" class="section active">
                <div class="chat-header">
                    <div class="tutor-info">
                        <div class="tutor-avatar">
                            <i class="fas fa-robot"></i>
                        </div>
                        <div class="tutor-details">
                            <h3>AI English Tutor</h3>
                            <span class="tutor-status"><i class="fas fa-circle online"></i> Online & Ready to Help</span>
                        </div>
                    </div>
                    <div class="chat-actions">
                        <button id="voice-settings-btn" class="btn btn-outline-light" type="button" title="Voice Settings">
                            <i class="fas fa-cog"></i>
                        </button>
                        <button class="btn btn-outline-light" type="button" title="Clear Chat">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                </div>
                
                <div class="chat-container">
                    <div class="chat-messages" id="chat-messages">
                        <!-- Connection status indicator -->
                        <div class="connection-status" id="connection-status">
                            <i class="fas fa-circle"></i>
                            <span>Connecting...</span>
                        </div>
                        <!-- Messages will be dynamically added here -->
                    </div>
                    
                    <div class="typing-indicator" id="typing-indicator" style="display: none;">
                        <div class="typing-dots">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <span class="typing-text">AI Tutor is typing...</span>
                    </div>
                </div>
                
                <div id="chat-input-container">
                    <div class="input-wrapper">
                        <div class="input-group">
                            <div class="input-icon">
                                <i class="fas fa-comment-dots"></i>
                            </div>
                            <input type="text" id="chat-input" placeholder="Ask me anything about English..." class="form-control">
                            <div class="input-actions">
                                <button id="voice-btn" class="btn btn-voice" type="button" title="Voice Input">
                                    <i class="fas fa-microphone"></i>
                                </button>
                                <button id="send-btn" class="btn btn-send" type="button" title="Send Message">
                                    <i class="fas fa-paper-plane"></i>
                                </button>
                            </div>
                        </div>
                        <div class="quick-suggestions">
                            <button class="suggestion-btn" data-text="Help me with grammar">
                                <i class="fas fa-spell-check"></i> Grammar Help
                            </button>
                            <button class="suggestion-btn" data-text="Practice conversation">
                                <i class="fas fa-comments"></i> Conversation
                            </button>
                            <button class="suggestion-btn" data-text="Explain vocabulary">
                                <i class="fas fa-book"></i> Vocabulary
                            </button>
                            <button class="suggestion-btn" data-text="Check pronunciation">
                                <i class="fas fa-volume-up"></i> Pronunciation
                            </button>
                        </div>
                        <div class="voice-controls-mini">
                            <div class="voice-status-mini" id="voice-status-mini">Ready</div>
                        </div>
                    </div>
                    
                    <!-- Voice Settings Panel -->
                    <div class="voice-settings-panel" id="voice-settings-panel" style="display: none;">
                        <div class="settings-content">
                            <h6><i class="fas fa-volume-up"></i> Voice Settings</h6>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="auto-speak-chat" checked>
                                <label class="form-check-label" for="auto-speak-chat">
                                    Auto-speak AI responses
                                    <small class="text-success" id="auto-speak-indicator-chat"> (Enabled)</small>
                                </label>
                            </div>
                            <div class="form-group" style="margin-top: 10px;">
                                <label for="voice-speed-chat">Speech Speed:</label>
                                <input type="range" id="voice-speed-chat" min="0.5" max="2" step="0.1" value="1" class="form-control-range">
                                <small class="form-text text-muted">Speed: <span id="speed-value-chat">1.0</span>x</small>
                            </div>
                            <div class="form-group" style="margin-top: 10px;">
                                <button type="button" id="test-voice-chat" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-volume-up"></i> Test Voice
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>