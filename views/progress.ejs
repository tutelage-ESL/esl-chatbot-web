<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESL Chatbot - Progress</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <h1>🤖 ESL Learning Assistant</h1>
            <%- include('partials/nav', { currentRoute: currentRoute }) %>
        </header>

        <main class="app-main">
            <section id="progress-section" class="section active">
                <h2>Your Learning Progress</h2>
                <div class="progress-summary">
                    <h3>Overall Progress: <span id="progress-percentage"><%= progress.progress %>%</span></h3>
                    <div class="progress-bar">
                        <div id="overall-progress" class="progress-fill" style="width: <%= progress.progress %>%;"></div>
                    </div>
                </div>
                <div class="progress-details">
                    <h3>Recent Activities</h3>
                    <div id="progress-list" class="progress-list">
  <p>Last updated: <%= progress.updatedAt.toLocaleString() %></p>
</div>
                </div>
            </section>
        </main>
    </div>

    
</body>
</html>